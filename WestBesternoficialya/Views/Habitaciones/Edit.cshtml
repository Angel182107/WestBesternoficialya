@model WestBesternoficialya.Models.Habitacion

<div class="container mt-4">
    <h2>Actualizar Habitación @Model.Numero</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="Numero" />
                <input type="hidden" asp-for="Tipo" />
                <input type="hidden" asp-for="Precio" />

                <div class="mb-3">
                    <label class="form-label">Cambiar Estado Operativo</label>
                    <select asp-for="Estado" class="form-control">
                        <option value="Limpia">Limpia (Disponible)</option>
                        <option value="Sucia">Sucia (Requiere Limpieza)</option>
                        <option value="Ocupada">Ocupada (Huésped adentro)</option>
                        <option value="Mantenimiento">En Mantenimiento</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-primary">Actualizar Estado</button>
                <a asp-action="Index" class="btn btn-secondary">Volver al Tablero</a>
            </form>
        </div>
    </div>
</div>