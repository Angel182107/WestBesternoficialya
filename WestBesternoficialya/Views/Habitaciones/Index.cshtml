@model IEnumerable<WestBesternoficialya.Models.Habitacion>

@{
    ViewData["Title"] = "Control de Habitaciones";
}

<div class="container mt-4">
    <h2>Habitaciones</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">Registrar Nueva Habitación</a>
    <hr />

    <div class="row">
        @foreach (var cuarto in Model)
        {
            // Definimos el color de la tarjeta según el estado de la habitación
            var colorBadge = "bg-success"; // Verde por defecto (Limpia)
            
            if (cuarto.Estado == "Sucia") { colorBadge = "bg-danger"; }
            else if (cuarto.Estado == "Ocupada") { colorBadge = "bg-primary"; }
            else if (cuarto.Estado == "Mantenimiento") { colorBadge = "bg-warning text-dark"; }

            <div class="col-md-3 mb-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <h4 class="card-title fw-bold">Habitación @cuarto.Numero</h4>
                        <p class="text-muted mb-2">@cuarto.Tipo</p>
                        <h5><span class="badge @colorBadge">@cuarto.Estado</span></h5>
                        <p class="card-text mt-2"><small class="text-muted">Precio: $@cuarto.Precio.ToString("0.00")</small></p>
                    </div>
                    <div class="card-footer bg-transparent border-0 text-center pb-3">
                        <a asp-action="Edit" asp-route-id="@cuarto.Id" class="btn btn-outline-secondary btn-sm">Cambiar Estado</a>
                        <a asp-action="Delete" asp-route-id="@cuarto.Id" class="btn btn-outline-danger btn-sm">Dar de Baja</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>