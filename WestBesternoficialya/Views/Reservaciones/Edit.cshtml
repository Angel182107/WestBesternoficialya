@model WestBesternoficialya.Models.Reservacion

<div class="container mt-4">
    <h2>Editar Reservación</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="EstadoReserva" />
                
                <div class="mb-3">
                    <label class="form-label">Nombre del Huésped</label>
                    <input asp-for="NombreCliente" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Teléfono de contacto</label>
                    <input asp-for="Telefono" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Habitación Asignada</label>
                    <select asp-for="HabitacionId" class="form-control" asp-items="ViewBag.Habitaciones" required></select>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha de Entrada</label>
                        <input asp-for="FechaEntrada" type="date" class="form-control" required />
                    </div>
                    <div class="col-md-6 mb-3">
                        <label class="form-label">Fecha de Salida</label>
                        <input asp-for="FechaSalida" type="date" class="form-control" required />
                    </div>
                </div>

                <div class="alert alert-info">
                    <small><i class="bi bi-info-circle"></i> Si cambias las fechas o la habitación, el sistema recalculará el total automáticamente.</small>
                </div>

                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>