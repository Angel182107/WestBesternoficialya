@model WestBesternoficialya.Models.Producto

<div class="container mt-4">
    <h2>Editar Producto</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label class="form-label">Nombre del Producto</label>
                    <input asp-for="Nombre" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Cantidad Actual</label>
                    <input asp-for="CantidadActual" type="number" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Stock Mínimo</label>
                    <input asp-for="StockMinimo" type="number" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Stock Máximo</label>
                    <input asp-for="StockMaximo" type="number" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Departamento asignado</label>
                    <select asp-for="DepartamentoId" class="form-control" asp-items="ViewBag.Departamentos"></select>
                </div>

                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            
            </form>
        </div>
    </div>
</div>