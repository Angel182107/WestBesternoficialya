@model WestBesternoficialya.Models.Producto

<div class="container mt-5 mb-5">
    <div class="card shadow-lg border-0 rounded-3" style="max-width: 600px; margin: auto;">

        <div class="card-header bg-primary text-white text-center rounded-top-3 py-3">
            <h3 class="mb-0"><i class="bi bi-box-seam"></i> Registrar Uso de Material</h3>
        </div>

        <div class="card-body p-4 bg-light">
            <form asp-action="Usar" method="post">
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label class="form-label fw-bold text-secondary">Producto</label>
                    <input type="text" class="form-control bg-white" value="@Model.Nombre" readonly />
                </div>

                <div class="row mb-4">
                    <div class="col-6">
                        <label class="form-label fw-bold text-secondary">Cantidad Disponible</label>
                        <input type="number" class="form-control bg-white text-center fs-5 fw-bold text-primary" value="@Model.CantidadActual" readonly />
                    </div>

                    <div class="col-6">
                        <label class="form-label fw-bold text-dark">Cantidad a Usar <span class="text-danger">*</span></label>
                        <input type="number" name="cantidadUsar" class="form-control border-primary text-center fs-5 fw-bold shadow-sm" min="1" max="@Model.CantidadActual" required autofocus placeholder="Ej. 5" />
                    </div>
                </div>

                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert alert-danger shadow-sm">
                        <div asp-validation-summary="All" class="text-danger mb-0 fw-bold"></div>
                    </div>
                }

                <hr class="mt-4 mb-4" />

                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">Cancelar</a>
                    <button type="submit" class="btn btn-success btn-lg px-4 shadow-sm fw-bold">
                        <i class="bi bi-check-circle"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>