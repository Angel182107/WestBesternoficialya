@{
    ViewData["Title"] = "Centro de Mando";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .tarjeta-dashboard {
        border-radius: 15px; /* Bordes más redonditos */
        border: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease; /* Animación suave */
    }

        .tarjeta-dashboard:hover {
            transform: translateY(-5px); /* Hace que flote hacia arriba al pasar el ratón */
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; /* Sombra más pronunciada */
        }

    .icono-gigante {
        font-size: 2.5rem;
        opacity: 0.8;
    }

    .fondo-degradado {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
    }
</style>

<div class="container mt-4">
    
    <div class="p-4 mb-5 shadow-sm fondo-degradado d-flex justify-content-between align-items-center">
        <div>
            <h2 class="fw-bold text-dark mb-1">¡Hola, Equipo San Pedro! 👋</h2>
            <p class="text-muted mb-0">Resumen en tiempo real de la operación de tu hotel.</p>
        </div>
        <div class="text-end d-none d-md-block">
            <p class="mb-0 text-muted fw-bold"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dddd, dd MMMM yyyy")</p>
        </div>
    </div>

    <div class="row mb-5">
        
        <div class="col-md-3 mb-4">
            <div class="card tarjeta-dashboard shadow-sm bg-white h-100 p-3 border-start border-danger border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Limpieza Pendiente</p>
                        <h2 class="fw-bold text-danger mb-0">@ViewBag.HabitacionesSucias</h2>
                    </div>
                    <i class="bi bi-droplet-half text-danger icono-gigante"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card tarjeta-dashboard shadow-sm bg-white h-100 p-3 border-start border-warning border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Alertas Almacén</p>
                        <h2 class="fw-bold text-warning mb-0">@ViewBag.AlertasAlmacen</h2>
                    </div>
                    <i class="bi bi-box-seam text-warning icono-gigante"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card tarjeta-dashboard shadow-sm bg-white h-100 p-3 border-start border-primary border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Personal Activo</p>
                        <h2 class="fw-bold text-primary mb-0">@ViewBag.TotalEmpleados</h2>
                    </div>
                    <i class="bi bi-people text-primary icono-gigante"></i>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card tarjeta-dashboard shadow-sm bg-white h-100 p-3 border-start border-success border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Avisos Activos</p>
                        <h2 class="fw-bold text-success mb-0">@ViewBag.TotalEventos</h2>
                    </div>
                    <i class="bi bi-megaphone text-success icono-gigante"></i>
                </div>
            </div>
        </div>

    </div>

    <h4 class="fw-bold mb-3"><i class="bi bi-lightning-charge-fill text-warning"></i> Accesos Directos</h4>
    <div class="row">
        <div class="col-md-4 mb-3">
            <a asp-controller="Habitaciones" asp-action="Index" class="btn btn-outline-danger w-100 p-3 text-start fw-bold tarjeta-dashboard">
                <i class="bi bi-arrow-right-circle me-2"></i> Revisar Cuartos Sucios
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a asp-controller="Eventos" asp-action="Create" class="btn btn-outline-success w-100 p-3 text-start fw-bold tarjeta-dashboard">
                <i class="bi bi-plus-circle me-2"></i> Publicar Nuevo Aviso
            </a>
        </div>
        <div class="col-md-4 mb-3">
            <a asp-controller="Productos" asp-action="Create" class="btn btn-outline-primary w-100 p-3 text-start fw-bold tarjeta-dashboard">
                <i class="bi bi-box-arrow-in-down me-2"></i> Registrar Suministros
            </a>
        </div>
    </div>

</div>