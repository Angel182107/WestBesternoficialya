@{
    ViewData["Title"] = "Centro de Mando";

    // 1. Obtenemos el nombre del usuario conectado
    string nombreUsuario = User.Identity?.Name ?? "Equipo";

    // 2. TRUCO: Si inician sesión con correo (ej. admin@hotel.com), cortamos el texto
    if (nombreUsuario.Contains("@"))
    {
        nombreUsuario = nombreUsuario.Split('@')[0];
        
        // Le ponemos la primera letra en mayúscula para que se vea bonito
        if (nombreUsuario.Length > 0)
        {
            nombreUsuario = char.ToUpper(nombreUsuario[0]) + nombreUsuario.Substring(1);
        }
    }
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    .tarjeta-dashboard {
        border-radius: 15px; /* Bordes más redonditos */
        border: none;
        transition: transform 0.2s ease, box-shadow 0.2s ease; /* Animación suave */
    }

        .tarjeta-dashboard:hover {
            transform: translateY(-5px); /* Hace que flote hacia arriba al pasar el ratón */
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important; /* Sombra más pronunciada */
        }

    .icono-gigante {
        font-size: 2.5rem;
        opacity: 0.8;
    }

    .fondo-degradado {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        border-radius: 15px;
    }
</style>

<div class="container mt-4">
    
    <div class="p-4 mb-5 shadow-sm fondo-degradado d-flex justify-content-between align-items-center">
        <div>
            <!-- Aquí aplicamos la variable con el nombre personalizado -->
            <h2 class="fw-bold text-dark mb-1">¡Bienvenido, @nombreUsuario! 👋</h2>
            <p class="text-muted mb-0">Resumen en tiempo real de la operación de tu hotel.</p>
        </div>
        <div class="text-end d-none d-md-block">
            <p class="mb-0 text-muted fw-bold"><i class="bi bi-calendar3"></i> @DateTime.Now.ToString("dddd, dd MMMM yyyy", new System.Globalization.CultureInfo("es-ES"))</p>
        </div>
    </div>

    <!-- TARJETAS DE INDICADORES (Ajustadas a col-md-4 para que las 3 ocupen todo el espacio) -->
    <div class="row mb-5">
        
        <div class="col-md-4 mb-4">
            <div class="card tarjeta-dashboard shadow-sm bg-white h-100 p-3 border-start border-warning border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Alertas Almacén</p>
                        <h2 class="fw-bold text-warning mb-0">@ViewBag.AlertasAlmacen</h2>
                    </div>
                    <i class="bi bi-box-seam text-warning icono-gigante"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card tarjeta-dashboard shadow-sm bg-white h-100 p-3 border-start border-primary border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Personal Activo</p>
                        <h2 class="fw-bold text-primary mb-0">@ViewBag.TotalEmpleados</h2>
                    </div>
                    <i class="bi bi-people text-primary icono-gigante"></i>
                </div>
            </div>
        </div>

        <div class="col-md-4 mb-4">
            <div class="card tarjeta-dashboard shadow-sm bg-white h-100 p-3 border-start border-success border-5">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <p class="text-muted text-uppercase small fw-bold mb-1">Avisos Activos</p>
                        <h2 class="fw-bold text-success mb-0">@ViewBag.TotalEventos</h2>
                    </div>
                    <i class="bi bi-megaphone text-success icono-gigante"></i>
                </div>
            </div>
        </div>

    </div>
</div>