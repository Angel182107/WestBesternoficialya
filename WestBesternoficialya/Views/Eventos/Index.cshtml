@model IEnumerable<WestBesternoficialya.Models.Evento>

<div class="container mt-4">
    <!-- CABECERA MODIFICADA -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Tablero de Avisos</h2>
        <div class="d-flex gap-2">
            <a asp-controller="Mantenimiento" asp-action="Index" class="btn btn-outline-info fw-bold shadow-sm">
                <i class="bi bi-tools"></i> Ver Reporte de Mantenimiento
            </a>
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
                <i class="bi bi-plus-circle"></i> Publicar Nuevo Aviso
            </a>
        </div>
    </div>
    <hr />

    @if (TempData["MensajeInfo"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>Aviso:</strong> @TempData["MensajeInfo"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>¡Éxito!</strong> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @foreach (var evento in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow h-100">
                    
                    <div class="card-header bg-dark text-white fw-bold">
                        Aviso del Hotel
                    </div>
                    
                    <div class="card-body">
                        <h5 class="card-title">@evento.Titulo</h5>
                        
                        @if (!string.IsNullOrEmpty(evento.DetallesLogistica))
                        {
                            <p class="card-text text-truncate">@evento.DetallesLogistica</p>
                        }

                        @if (!string.IsNullOrEmpty(evento.Grupo) || !string.IsNullOrEmpty(evento.Folio) || evento.Fecha != null)
                        {
                            <div class="mt-2 mb-2">
                                <span class="badge bg-secondary"><i class="bi bi-file-earmark-spreadsheet"></i> Contiene Instructivo de Grupo</span>
                            </div>
                        }
                        
                        <p class="text-muted small mb-0 mt-3">Fecha: @evento.FechaCreacion.ToString("dd/MM/yyyy")</p>
                        <p class="text-muted small">Publicado por: <strong>@(evento.Creador ?? "Administrador")</strong></p>
                    </div>
                    
                    <div class="card-footer bg-transparent text-center border-top-0">
                        <a asp-action="Details" asp-route-id="@evento.Id" class="btn btn-primary btn-sm mb-1 w-100"><i class="bi bi-eye"></i> Abrir Documento</a>
                        
                        <div class="mt-1">
                            <a asp-action="Firmar" asp-route-id="@evento.Id" class="btn btn-success btn-sm mb-1">Marcar de Enterado</a>
                            <a asp-action="ReporteFirmas" asp-route-id="@evento.Id" class="btn btn-info btn-sm mb-1 text-white">Ver Firmas</a>
                        
                            @if (evento.Creador == User.Identity.Name)
                            {
                                <a asp-action="Edit" asp-route-id="@evento.Id" class="btn btn-warning btn-sm mb-1">Editar</a>
                                <a asp-action="Delete" asp-route-id="@evento.Id" class="btn btn-danger btn-sm mb-1">Borrar</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>