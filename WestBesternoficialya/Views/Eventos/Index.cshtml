@model IEnumerable<WestBesternoficialya.Models.Evento>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">Tablero de Avisos</h2>

        <div class="d-flex gap-2">
            <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm">
                <i class="bi bi-plus-circle"></i> Publicar Nuevo Aviso
            </a>
        </div>
    </div>
    <hr />

    @if (TempData["MensajeInfo"] != null)
    {
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            <strong>Aviso:</strong> @TempData["MensajeInfo"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["MensajeExito"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <strong>¡Éxito!</strong> @TempData["MensajeExito"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["MensajeError"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <strong>Error:</strong> @TempData["MensajeError"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        @foreach (var evento in Model)
        {
            // =======================================================
            // LÓGICA MÁGICA: Separamos el texto de los archivos
            // =======================================================
            string textoAviso = "";
            string archivosAdjuntos = "";

            if (!string.IsNullOrEmpty(evento.DetallesLogistica))
            {
                if (evento.DetallesLogistica.Contains("===ARCHIVOS==="))
                {
                    var partes = evento.DetallesLogistica.Split(new[] { "===ARCHIVOS===" }, StringSplitOptions.None);
                    textoAviso = partes[0];
                    if (partes.Length > 1) { archivosAdjuntos = partes[1]; }
                }
                else if (evento.DetallesLogistica.Contains("::"))
                {
                    archivosAdjuntos = evento.DetallesLogistica; // Formato viejo (solo archivos)
                }
                else
                {
                    textoAviso = evento.DetallesLogistica; // Formato viejo (solo texto)
                }
            }

            <div class="col-md-4 mb-4">
                <div class="card shadow h-100 border-0 rounded-3">

                    <div class="card-header bg-dark text-white fw-bold">
                        Aviso del Hotel
                    </div>

                    <div class="card-body">
                        <h5 class="card-title text-primary fw-bold">@evento.Titulo</h5>

                        @if (!string.IsNullOrWhiteSpace(textoAviso))
                        {
                            <p class="card-text mt-3 text-secondary" style="white-space: pre-wrap;">@textoAviso</p>
                        }

                        @if (!string.IsNullOrEmpty(archivosAdjuntos))
                        {
                            int numArchivos = archivosAdjuntos.Split('|').Length;
                            <div class="mt-3 mb-2">
                                <span class="badge bg-secondary"><i class="bi bi-collection"></i> @numArchivos Archivo(s) Adjunto(s)</span>
                            </div>
                        }

                        <hr class="text-muted" />
                        <p class="text-muted small mb-0">Fecha: @evento.FechaCreacion.ToString("dd/MM/yyyy")</p>
                        <p class="text-muted small mb-0">Publicado por: <strong class="text-dark">@(evento.Creador ?? "Administrador")</strong></p>
                    </div>

                    <div class="card-footer bg-light text-center border-top-0 pt-3 pb-3">

                        @if (!string.IsNullOrEmpty(archivosAdjuntos))
                        {
                            var archivos = archivosAdjuntos.Split('|');
                            foreach (var arch in archivos)
                            {
                                if (arch.Contains("::"))
                                {
                                    var datosArchivo = arch.Split("::");
                                    if (datosArchivo.Length == 2)
                                    {
                                        var nombreOriginal = datosArchivo[0];
                                        var rutaArchivo = datosArchivo[1];

                                        <a href="@rutaArchivo" target="_blank" class="btn btn-outline-primary btn-sm mb-2 w-100 fw-bold shadow-sm" title="@nombreOriginal">
                                            <i class="bi bi-file-earmark-text me-1"></i> ABRIR: @(nombreOriginal.Length > 20 ? nombreOriginal.Substring(0, 17) + "..." : nombreOriginal)
                                        </a>
                                    }
                                }
                            }
                        }

                        <div class="mt-2 d-flex justify-content-center gap-1 flex-wrap">
                            <a asp-action="Firmar" asp-route-id="@evento.Id" class="btn btn-success btn-sm shadow-sm fw-bold">ENTERADO</a>
                            <a asp-action="ReporteFirmas" asp-route-id="@evento.Id" class="btn btn-info btn-sm text-white shadow-sm fw-bold">VER FIRMAS</a>

                            @if (evento.Creador == User.Identity?.Name || User.IsInRole("Administrador"))
                            {
                                <a asp-action="Edit" asp-route-id="@evento.Id" class="btn btn-warning btn-sm shadow-sm fw-bold text-dark">EDITAR</a>
                                <a asp-action="Delete" asp-route-id="@evento.Id" class="btn btn-danger btn-sm shadow-sm fw-bold">BORRAR</a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div> <div class="d-flex justify-content-center align-items-center mt-4 mb-5 gap-2">
    @if (ViewBag.PaginaActual > 1)
    {
        <a asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual - 1)" class="btn btn-outline-primary fw-bold shadow-sm">
            <i class="bi bi-chevron-left"></i> Anterior
        </a>
    }

    <span class="btn btn-primary disabled fw-bold shadow-sm">
        Página @ViewBag.PaginaActual de @(ViewBag.TotalPaginas == 0 ? 1 : ViewBag.TotalPaginas)
    </span>

    @if (ViewBag.PaginaActual < ViewBag.TotalPaginas)
    {
        <a asp-action="Index" asp-route-pagina="@(ViewBag.PaginaActual + 1)" class="btn btn-outline-primary fw-bold shadow-sm">
            Siguiente <i class="bi bi-chevron-right"></i>
        </a>
    }
</div>
</div>