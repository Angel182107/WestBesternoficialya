                            <p class="fs-5" style="white-space: pre-wrap;">@Model.DetallesLogistica</p>
                            <hr class="mt-5" />
                            <div class="text-muted small">
                                <p class="mb-0"><strong>Publicado por:</strong> @(Model.Creador ?? "Administrador")</p>
                                <p class="mb-0"><strong>Fecha de Publicación:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy hh:mm tt")</p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="formato-impresion" style="max-width: 1000px; margin: auto; background-color: white; padding: 30px; border: 1px solid #ccc; font-family: Arial, sans-serif;">

                        <div class="p-3 mb-3 border border-dark" style="background-color: #e2e3e5;">
                            <h2 class="text-center fw-bold mb-3" style="letter-spacing: 2px;">HOTEL SAN PEDRO</h2>
                            <div class="d-flex justify-content-between fw-bold fs-5">
                                <div>INSTRUCTIVO DE GRUPO</div>
                                <div>FOLIO @(Model.Folio ?? "____")</div>
                            </div>
                        </div>

                        <table class="table table-bordered border-dark mt-0" style="font-size: 0.9rem;">
