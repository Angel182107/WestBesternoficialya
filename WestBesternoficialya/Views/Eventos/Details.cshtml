                                    <td>@(habD > 0 ? habD.ToString() : "-")</td>
                                    <td>@(paxD > 0 ? paxD.ToString() : "-")</td>
                                    <td>@(nocD > 0 ? nocD.ToString() : "-")</td>
                                    <td>@(totD > 0 ? totD.ToString("C") : "$ -")</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaDoble) ? "-" : Model.PropinaDoble)</td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">TRIPLE</td>
                                    <td>@(Model.TarifaTriple != null ? Model.TarifaTriple?.ToString("C") : "$ -")</td>
                                    <td>@(habT > 0 ? habT.ToString() : "-")</td>
                                    <td>@(paxT > 0 ? paxT.ToString() : "-")</td>
                                    <td>@(nocT > 0 ? nocT.ToString() : "-")</td>
                                    <td>@(totT > 0 ? totT.ToString("C") : "$ -")</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaTriple) ? "-" : Model.PropinaTriple)</td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">CUÁDRUPLE</td>
                                    <td>@(Model.TarifaCuadruple != null ? Model.TarifaCuadruple?.ToString("C") : "$ -")</td>
                                    <td>@(habC > 0 ? habC.ToString() : "-")</td>
                                    <td>@(paxC > 0 ? paxC.ToString() : "-")</td>
                                    <td>@(nocC > 0 ? nocC.ToString() : "-")</td>
                                    <td>@(totC > 0 ? totC.ToString("C") : "$ -")</td>
