                                    <td>@(paxS > 0 ? paxS.ToString() : "-")</td>
                                    <td>@(nocS > 0 ? nocS.ToString() : "-")</td>
                                    <td>@(totS > 0 ? totS.ToString("C") : "$ -")</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaSencilla) ? "-" : Model.PropinaSencilla)</td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">DOBLE</td>
