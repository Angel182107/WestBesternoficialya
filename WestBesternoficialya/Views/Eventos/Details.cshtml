                                    <td>@alimentos.Montaje</td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="fw-bold text-center border border-dark border-bottom-0 mt-3" style="background-color: #d1d1d1;">COSTOS:</div>
                        <table class="table table-bordered border-dark text-center mb-0" style="font-size: 0.85rem;">
                            <thead>
                                <tr style="background-color: #ffff00;">
                                    <th style="width: 15%;" class="bg-light">CONCEPTO:</th>
                                    <th style="width: 15%;"></th>
                                    <th style="width: 20%;">@alimentos.ConceptoServicio</th>
                                    <th style="width: 15%;"></th>
                                    <th style="width: 15%;"></th>
                                    <th style="width: 20%;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold bg-light">PRECIO:</td>
                                    <td></td>
                                    <td>$ @(alimentos.Precio?.ToString("0.00") ?? "-")</td>
                                    <td>$ -</td>
                                    <td>$ -</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">IVA:</td>
                                    <td>0.16</td>
                                    <td>$ @(alimentos.Iva?.ToString("0.00") ?? "-")</td>
                                    <td>$ -</td>
                                    <td>$ -</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">SERVICIO:</td>
                                    <td>0.08</td>
                                    <td>$ @(alimentos.Servicio?.ToString("0.00") ?? "-")</td>
                                    <td>$ -</td>
                                    <td>$ -</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">SUBTOTAL:</td>
                                    <td></td>
                                    <td>$ @(alimentos.Subtotal?.ToString("0.00") ?? "-")</td>
                                    <td>$ -</td>
                                    <td>$ -</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">NO. PAX:</td>
                                    <td colspan="4" class="text-center">@alimentos.NoPax</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">NO. DÍAS:</td>
                                    <td>@alimentos.NoDias</td>
                                    <td>$ @(alimentos.Total?.ToString("0.00") ?? "-")</td>
                                    <td>$ -</td>
                                    <td>$ -</td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="fw-bold bg-light text-end pe-3">TOTAL:</td>
                                    <td colspan="4" class="fw-bold fs-6">$ @(alimentos.Total?.ToString("0.00") ?? "-")</td>
                                </tr>
                            </tbody>
                        </table>

                        <table class="table table-bordered border-dark text-center mt-0 mb-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td style="width: 50%;" class="fw-bold bg-light">CORTESÍAS:</td>
                                    <td style="width: 50%;" class="fw-bold bg-light">PAGO:</td>
                                </tr>
                                <tr>
                                    <td class="p-3 fw-bold" style="min-height: 80px; text-transform: uppercase;">@alimentos.Cortesias</td>
                                    <td class="p-3 fw-bold text-decoration-underline" style="min-height: 80px; text-transform: uppercase;">@alimentos.Pago</td>
                                </tr>
                                <tr>
                                    <td rowspan="2" class="p-4 fw-bold" style="color: #084298;">@alimentos.Observaciones</td>
                                    <td class="fw-bold bg-light">OBSERVACIONES:</td>
                                </tr>
                                <tr>
                                    <td class="p-4 fw-bold fs-5 text-decoration-underline" style="background-color: #ffff00; text-transform: uppercase;">
                                        @alimentos.ClienteEmpresa
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-warning text-center shadow-sm p-5 mt-4 rounded-4">
                    <h4><i class="bi bi-exclamation-triangle text-warning"></i> Archivo No Encontrado</h4>
                    <p class="fs-5">Este grupo aún no tiene una Notificación de Evento (Alimentos y Salones) registrada.</p>
                    <a asp-controller="NotificacionesEventos" asp-action="Create" asp-route-eventoId="@Model.Id" class="btn btn-success fw-bold px-4 shadow mt-3">
                        <i class="bi bi-file-earmark-plus"></i> Crear Nuevo Archivo
                    </a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>

<!-- LIBRERÍA Y SCRIPT MÁGICO PARA DESCARGAR PDFs PERFECTOS -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    function descargarPDF(divId, nombreArchivo) {
    var elemento = document.getElementById(divId);

    // 1. Guardamos tu diseño original tal y como lo hiciste
    var estiloOriginal = elemento.getAttribute("style");

    // 2. Encogemos el formato al tamaño exacto de una hoja física (Letter)
    // También quitamos el borde gris para que el PDF parezca una hoja en blanco real
    elemento.style.maxWidth = "780px";
    elemento.style.padding = "20px";
    elemento.style.margin = "0";
    elemento.style.border = "none";

    var opciones = {
    margin:       0.3, // Margen de la hoja (en pulgadas)
    filename:     nombreArchivo + '.pdf',
    image:        { type: 'jpeg', quality: 1 },
    html2canvas:  { scale: 2, useCORS: true }, // Escala 2 para que la letra no se vea borrosa
    jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
    };

    // 3. Tomamos la "foto", generamos el PDF y lo descargamos
    html2pdf().set(opciones).from(elemento).save().then(function() {
    // 4. Una vez descargado, regresamos tu diseño a 1000px en la pantalla para que siga viéndose igual
    elemento.setAttribute("style", estiloOriginal);
    });
    }
</script>