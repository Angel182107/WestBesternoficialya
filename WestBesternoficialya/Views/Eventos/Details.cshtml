@model WestBesternoficialya.Models.Evento

@{
    ViewData["Title"] = "Detalles del Aviso";
}

<div class="container mt-4 mb-5">

    <!-- BOTONES SUPERIORES -->
    <div class="d-print-none mb-4 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-secondary shadow-sm">
            <i class="bi bi-arrow-left"></i> Volver al Tablero
        </a>
        <div>
            <a asp-action="Firmar" asp-route-id="@Model.Id" class="btn btn-success ms-2 shadow-sm fw-bold">
                <i class="bi bi-check-circle"></i> Marcar de Enterado
            </a>
        </div>
    </div>

    <!-- TARJETA PRINCIPAL DEL AVISO -->
    <div class="card shadow-lg border-primary border-0 rounded-3">
        <div class="card-header bg-primary text-white py-3">
            <h4 class="mb-0"><i class="bi bi-info-circle me-2"></i> @Model.Titulo</h4>
        </div>

        <div class="card-body p-4 bg-light">

            <h5 class="text-dark fw-bold mb-4">Documentos Adjuntos</h5>

            @if (!string.IsNullOrEmpty(Model.DetallesLogistica))
            {
                // LÓGICA PARA MOSTRAR MÚLTIPLES ARCHIVOS NUEVOS
                if (Model.DetallesLogistica.Contains("::"))
                {
                    <div class="d-flex flex-wrap gap-2 mb-4">
                        @{
                            var archivos = Model.DetallesLogistica.Split('|');
                            foreach (var arch in archivos)
                            {
                                var datosArchivo = arch.Split("::");
                                if (datosArchivo.Length == 2)
                                {
                                    var nombreOriginal = datosArchivo[0];
                                    var rutaArchivo = datosArchivo[1];

                                    <a href="@rutaArchivo" target="_blank" class="btn btn-outline-primary shadow-sm fw-bold py-2 px-3" title="@nombreOriginal">
                                        <i class="bi bi-file-earmark-text fs-5 align-middle me-1"></i> ABRIR: @nombreOriginal
                                    </a>
                                }
                            }
                        }
                    </div>
                }
                // COMPATIBILIDAD CON AVISOS VIEJOS (UN SOLO ARCHIVO)
                else if (Model.DetallesLogistica.StartsWith("/uploads/"))
                {
                    <div class="mb-4">
                        <a href="@Model.DetallesLogistica" target="_blank" class="btn btn-outline-primary shadow-sm fw-bold py-2 px-3">
                            <i class="bi bi-folder2-open fs-5 align-middle me-1"></i> Abrir Archivo Adjunto
                        </a>
                    </div>
                }
                // SI SOLO ES TEXTO (POR SI ACASO)
                else
                {
                    <div class="bg-white p-3 border rounded shadow-sm mb-4">
                        <p class="fs-5 mb-0" style="white-space: pre-wrap;">@Model.DetallesLogistica</p>
                    </div>
                }
            }
            else
            {
                <div class="alert alert-secondary text-center shadow-sm">
                    <i class="bi bi-exclamation-circle text-secondary fs-4 d-block mb-2"></i>
                    <p class="mb-0">Este aviso no contiene archivos adjuntos ni detalles adicionales.</p>
                </div>
            }

            <hr class="mt-4 mb-4" />

            <!-- PIE DE PÁGINA CON DATOS DEL CREADOR -->
            <div class="text-muted small d-flex justify-content-between bg-white p-3 rounded border">
                <span><i class="bi bi-person-badge"></i> <strong>Publicado por:</strong> @(Model.Creador ?? "Administrador")</span>
                <span><i class="bi bi-calendar3"></i> <strong>Fecha:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy hh:mm tt")</span>
            </div>

        </div>
    </div>
</div>