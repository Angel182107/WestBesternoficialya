                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">CORTESÍA</td>
                                    <td>@(Model.TarifaCortesia != null ? Model.TarifaCortesia?.ToString("C") : "$ -")</td>
                                    <td>@(habCor > 0 ? habCor.ToString() : "-")</td>
                                    <td>@(paxCor > 0 ? paxCor.ToString() : "-")</td>
                                    <td>@(nocCor > 0 ? nocCor.ToString() : "-")</td>
                                    <td>@(totCor > 0 ? totCor.ToString("C") : "$ -")</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaCortesia) ? "-" : Model.PropinaCortesia)</td>
                                </tr>
                                <tr class="fw-bold">
                                    <td class="border-0"></td>
                                    <td class="border-0"></td>
                                    <td class="border-dark">@(totalHabs > 0 ? totalHabs.ToString() : "-")</td>
                                    <td class="border-dark">@(totalPax > 0 ? totalPax.ToString() : "-")</td>
                                    <td class="text-center bg-light border-dark">HOSPEDAJE:</td>
