@model WestBesternoficialya.Models.Evento

@{
    ViewData["Title"] = "Detalles del Aviso y Formatos";
    bool esInstructivoGrupo = !string.IsNullOrEmpty(Model.Grupo) || !string.IsNullOrEmpty(Model.Folio) || Model.Fecha != null;

    // ==========================================
    // CÁLCULOS DEL INSTRUCTIVO (FORMATO 1)
    // ==========================================
    int habS = Model.Sencillas ?? 0;
    int habD = Model.Dobles ?? 0;
    int habT = Model.Triples ?? 0;
    int habC = Model.Cuadruples ?? 0;
    int habCor = Model.CortesiasHabitacion ?? 0;

    int nocS = Model.NochesSencilla ?? 0;
    int nocD = Model.NochesDoble ?? 0;
    int nocT = Model.NochesTriple ?? 0;
    int nocC = Model.NochesCuadruple ?? 0;
    int nocCor = Model.NochesCortesia ?? 0;

    int paxS = habS * 1;
    int paxD = habD * 2;
    int paxT = habT * 3;
    int paxC = habC * 4;
    int paxCor = 0;

    decimal totS = habS * (Model.TarifaSencilla ?? 0) * nocS;
    decimal totD = habD * (Model.TarifaDoble ?? 0) * nocD;
    decimal totT = habT * (Model.TarifaTriple ?? 0) * nocT;
    decimal totC = habC * (Model.TarifaCuadruple ?? 0) * nocC;
    decimal totCor = habCor * (Model.TarifaCortesia ?? 0) * nocCor;

    int totalHabs = habS + habD + habT + habC + habCor;
    int totalPax = paxS + paxD + paxT + paxC + paxCor;

    decimal sumaHospedaje = totS + totD + totT + totC + totCor;
    decimal totalAlimentos = Model.CostoAlimentos ?? 0;
    decimal totalPropinas = Model.CostoPropinas ?? 0;
    decimal totalEvento = Model.TotalEvento ?? (sumaHospedaje + totalAlimentos + totalPropinas);

    // Extraemos los formatos adicionales de la charola
    var alimentos = ViewBag.Alimentos as WestBesternoficialya.Models.NotificacionEvento;
    var memo = ViewBag.Memorandum as WestBesternoficialya.Models.Memorandum;
    bool esMemorandum = memo != null;
        
    // Verificamos si el usuario pertenece a Ama de Llaves para ocultar tarifas
    bool esAmaLlaves = User.IsInRole("Ama de llaves");
}

<div class="container mt-4 mb-5">

    <div class="d-print-none mb-4 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver al Tablero</a>
        <div>
            <a asp-action="Firmar" asp-route-id="@Model.Id" class="btn btn-success ms-2">
                <i class="bi bi-check-circle"></i> Marcar de Enterado
            </a>
        </div>
    </div>

    <!-- PESTAÑAS DE NAVEGACIÓN -->
    <ul class="nav nav-tabs mb-4" id="formatosTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold fs-5 text-dark" id="instructivo-tab" data-bs-toggle="tab" data-bs-target="#instructivo-panel" type="button" role="tab">
                📄 1. Instructivo de Grupo
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold fs-5 text-dark" id="alimentos-tab" data-bs-toggle="tab" data-bs-target="#alimentos-panel" type="button" role="tab">
                🍽️ 2. Notificación de Evento
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold fs-5 text-dark" id="memorandum-tab" data-bs-toggle="tab" data-bs-target="#memorandum-panel" type="button" role="tab">
                📝 3. Memorándum
            </button>
        </li>
    </ul>

    <!-- CONTENIDO DE LAS PESTAÑAS -->
    <div class="tab-content" id="formatosTabContent">

        <!-- ============================================== -->
        <!-- PESTAÑA 1: INSTRUCTIVO DE GRUPO                -->
        <!-- ============================================== -->
        <div class="tab-pane fade show active" id="instructivo-panel" role="tabpanel">
            <div class="text-end mb-3">
                @if (esInstructivoGrupo)
                {
                    <button onclick="descargarPDF('documento-instructivo', 'Instructivo_@Model.Folio')" class="btn btn-danger shadow-sm">
                        <i class="bi bi-file-earmark-pdf"></i> Descargar PDF (Instructivo)
                    </button>
                }
            </div>

            <div id="documento-instructivo">
                @if (!esInstructivoGrupo)
                {
                    <div class="card shadow border-primary">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0">@Model.Titulo</h4>
                        </div>
                        <div class="card-body p-4">
                            <h5 class="text-primary mb-3"><i class="bi bi-megaphone"></i> Comunicado General</h5>
                            <p class="fs-5" style="white-space: pre-wrap;">@Model.DetallesLogistica</p>
                            <hr class="mt-5" />
                            <div class="text-muted small">
                                <p class="mb-0"><strong>Publicado por:</strong> @(Model.Creador ?? "Administrador")</p>
                                <p class="mb-0"><strong>Fecha de Publicación:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy hh:mm tt")</p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    <div class="formato-impresion" style="max-width: 1000px; margin: auto; background-color: white; padding: 30px; border: 1px solid #ccc; font-family: Arial, sans-serif;">

                        <div class="p-3 mb-3 border border-dark" style="background-color: #e2e3e5;">
                            <h2 class="text-center fw-bold mb-3" style="letter-spacing: 2px;">HOTEL SAN PEDRO</h2>
                            <div class="d-flex justify-content-between fw-bold fs-5">
                                <div>INSTRUCTIVO DE GRUPO</div>
                                <div>FOLIO @(Model.Folio ?? "____")</div>
                            </div>
                        </div>

                        <table class="table table-bordered border-dark mt-0" style="font-size: 0.9rem;">
                            <tr>
                                <td style="width: 15%;" class="bg-light"><strong>Fecha:</strong></td>
                                <td style="width: 35%;">@(Model.Fecha?.ToString("dd-MMM-yy") ?? "---")</td>
                                <td style="width: 15%;" class="bg-light"><strong>Grupo:</strong></td>
                                <td style="width: 35%;" class="fw-bold text-uppercase">@(Model.Grupo ?? "---")</td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Agencia:</strong></td>
                                <td>@Model.Agencia</td>
                                <td class="bg-light"><strong>Tipo Grupo:</strong></td>
                                <td>@Model.TipoGrupo</td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Dirección:</strong></td>
                                <td>@Model.Direccion</td>
                                <td class="bg-light"><strong>Teléfono:</strong></td>
                                <td>@Model.Telefono</td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Coordinador:</strong></td>
                                <td>@Model.Coordinador</td>
                                <td class="bg-light"><strong>R.F.C.:</strong></td>
                                <td>@Model.Rfc</td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Ejecutivo:</strong></td>
                                <td>@Model.Ejecutivo</td>
                                <td class="bg-light"><strong>Ant:</strong></td>
                                <td>@Model.Ant</td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Fecha Entrada:</strong></td>
                                <td class="fw-bold">@(Model.FechaEntrada?.ToString("dd/MM/yyyy") ?? "---")</td>
                                <td class="bg-light"><strong>Fecha Salida:</strong></td>
                                <td class="fw-bold">@(Model.FechaSalida?.ToString("dd/MM/yyyy") ?? "---")</td>
                            </tr>
                            <tr>
                                <td colspan="2"></td>
                                <td class="bg-light"><strong>Hora Llegada:</strong></td>
                                <td>@Model.HoraLlegada</td>
                            </tr>
                        </table>

                        <table class="table table-bordered border-dark text-center mb-0" style="font-size: 0.85rem;">
                            <thead class="bg-light">
                                <tr class="align-middle">
                                    <th style="width: 15%;"></th>
                                    <th style="width: 15%;">TARIFAS</th>
                                    <th style="width: 14%;">N° DE HAB</th>
                                    <th style="width: 10%;">PAX</th>
                                    <th style="width: 10%;">NOCHES</th>
                                    <th style="width: 20%;">TOTAL</th>
                                    <th style="width: 16%;">PROPINA</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-center fw-bold">SENCILLA</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (Model.TarifaSencilla != null ? Model.TarifaSencilla?.ToString("C") : "$ -"))</td>
                                    <td>@(habS > 0 ? habS.ToString() : "-")</td>
                                    <td>@(paxS > 0 ? paxS.ToString() : "-")</td>
                                    <td>@(nocS > 0 ? nocS.ToString() : "-")</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (totS > 0 ? totS.ToString("C") : "$ -"))</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaSencilla) ? "-" : Model.PropinaSencilla)</td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">DOBLE</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (Model.TarifaDoble != null ? Model.TarifaDoble?.ToString("C") : "$ -"))</td>
                                    <td>@(habD > 0 ? habD.ToString() : "-")</td>
                                    <td>@(paxD > 0 ? paxD.ToString() : "-")</td>
                                    <td>@(nocD > 0 ? nocD.ToString() : "-")</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (totD > 0 ? totD.ToString("C") : "$ -"))</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaDoble) ? "-" : Model.PropinaDoble)</td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">TRIPLE</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (Model.TarifaTriple != null ? Model.TarifaTriple?.ToString("C") : "$ -"))</td>
                                    <td>@(habT > 0 ? habT.ToString() : "-")</td>
                                    <td>@(paxT > 0 ? paxT.ToString() : "-")</td>
                                    <td>@(nocT > 0 ? nocT.ToString() : "-")</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (totT > 0 ? totT.ToString("C") : "$ -"))</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaTriple) ? "-" : Model.PropinaTriple)</td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">CUÁDRUPLE</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (Model.TarifaCuadruple != null ? Model.TarifaCuadruple?.ToString("C") : "$ -"))</td>
                                    <td>@(habC > 0 ? habC.ToString() : "-")</td>
                                    <td>@(paxC > 0 ? paxC.ToString() : "-")</td>
                                    <td>@(nocC > 0 ? nocC.ToString() : "-")</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (totC > 0 ? totC.ToString("C") : "$ -"))</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaCuadruple) ? "-" : Model.PropinaCuadruple)</td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">CORTESÍA</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (Model.TarifaCortesia != null ? Model.TarifaCortesia?.ToString("C") : "$ -"))</td>
                                    <td>@(habCor > 0 ? habCor.ToString() : "-")</td>
                                    <td>@(paxCor > 0 ? paxCor.ToString() : "-")</td>
                                    <td>@(nocCor > 0 ? nocCor.ToString() : "-")</td>
                                    <td>@(esAmaLlaves ? "$ ----" : (totCor > 0 ? totCor.ToString("C") : "$ -"))</td>
                                    <td>@(string.IsNullOrEmpty(Model.PropinaCortesia) ? "-" : Model.PropinaCortesia)</td>
                                </tr>
                                <tr class="fw-bold">
                                    <td class="border-0"></td>
                                    <td class="border-0"></td>
                                    <td class="border-dark">@(totalHabs > 0 ? totalHabs.ToString() : "-")</td>
                                    <td class="border-dark">@(totalPax > 0 ? totalPax.ToString() : "-")</td>
                                    <td class="text-center bg-light border-dark">HOSPEDAJE:</td>
                                    <td class="text-end border-dark">@(esAmaLlaves ? "$ ----" : sumaHospedaje.ToString("C"))</td>
                                    <td class="text-end border-dark">-</td>
                                </tr>
                                <tr class="fw-bold">
                                    <td colspan="4" class="border-0"></td>
                                    <td class="text-center bg-light border-dark">ALIMENTOS:</td>
                                    <td class="text-end border-dark">@(esAmaLlaves ? "$ ----" : totalAlimentos.ToString("C"))</td>
                                    <td class="border-0"></td>
                                </tr>
                                <tr class="fw-bold">
                                    <td colspan="4" class="border-0"></td>
                                    <td class="text-center bg-light border-dark">PROPINAS:</td>
                                    <td class="text-end border-dark">@(esAmaLlaves ? "$ ----" : totalPropinas.ToString("C"))</td>
                                    <td class="border-0"></td>
                                </tr>
                                <tr class="fw-bold">
                                    <td colspan="4" class="border-0"></td>
                                    <td class="text-center bg-light border-dark">TOTAL<br />EVENTO:</td>
                                    <td class="text-end border-dark">@(esAmaLlaves ? "$ ----" : totalEvento.ToString("C"))</td>
                                    <td class="border-0"></td>
                                </tr>
                            </tbody>
                        </table>

                        @if (!esAmaLlaves)
                        {
                            <table class="table table-bordered border-dark mt-3 mb-0" style="font-size: 0.85rem;">
                                <tr class="bg-light">
                                    <td colspan="2" class="fw-bold">NO. DE RESERVACIÓN: <span class="bg-white px-3 border border-dark ms-2">@Model.NumeroReservacion</span></td>
                                </tr>
                                <tr>
                                    <td style="width: 20%;" class="bg-light"><strong>Cta. Maestra:</strong></td>
                                    <td style="width: 80%;">@Model.CuentaMaestra</td>
                                </tr>
                                <tr>
                                    <td class="bg-light"><strong>Cta. Individual:</strong></td>
                                    <td>@Model.CuentasIndividuales</td>
                                </tr>
                            </table>
                        }

                        <table class="table table-bordered border-dark @(esAmaLlaves ? "mt-3" : "mt-0 border-top-0")" style="font-size: 0.85rem;">
                            <tbody>
                                <tr>
                                    <td style="width: 20%; vertical-align: middle;" class="bg-white text-center">
                                        <strong class="bg-light px-2 py-1 border border-dark d-inline-block">OBSERVACIONES:</strong>
                                    </td>
                                    <td style="width: 80%; background-color: #cfe2ff; color: #084298; text-align: center; vertical-align: middle;" class="fw-bold fs-4 px-4">
                                        @(string.IsNullOrEmpty(Model.Observaciones) ? "\"BRINDAR EL SERVICIO QUE NOS CARACTERIZA\"" : $"\"{Model.Observaciones.ToUpper()}\"")
                                    </td>
                                </tr>
                                <tr><td class="bg-light"><strong>CORTESÍAS:</strong></td><td>@Model.CortesiasExtras</td></tr>
                                <tr><td class="bg-light"><strong>ANTICIPO:</strong></td><td>@Model.Anticipo</td></tr>
                                <tr><td class="bg-light"><strong>FACTURAR A:</strong></td><td>@Model.FacturarA</td></tr>
                                <tr><td class="bg-light"><strong>DOMICILIO:</strong></td><td>@Model.DomicilioFacturacion</td></tr>
                                <tr><td class="bg-light"><strong>R.F.C.:</strong></td><td>@Model.RfcFacturacion</td></tr>
                                <tr><td class="bg-light"><strong>TELÉFONO FACT.:</strong></td><td>@Model.TelefonoFacturacion</td></tr>
                                <tr><td class="bg-light"><strong>TELÉFONO GUÍA:</strong></td><td>@Model.Guia</td></tr>
                                <tr><td class="bg-light"><strong>DESPERTADOR:</strong></td><td>@Model.Despertador</td></tr>
                                <tr><td class="bg-light"><strong>ALIMENTOS:</strong></td><td>@Model.NotasAlimentos</td></tr>
                                <tr><td class="bg-light"><strong>EQUIPAJE:</strong></td><td>@Model.Equipaje</td></tr>
                            </tbody>
                        </table>
                    </div>
                }
            </div>
        </div>

        <!-- ============================================== -->
        <!-- PESTAÑA 2: NOTIFICACIÓN DE EVENTO (ALIMENTOS)  -->
        <!-- ============================================== -->
        <div class="tab-pane fade" id="alimentos-panel" role="tabpanel">
            @if (alimentos != null)
            {
                <div class="text-end mb-3">
                    <button onclick="descargarPDF('documento-alimentos', 'Notificacion_@alimentos.Folio')" class="btn btn-danger shadow-sm">
                        <i class="bi bi-file-earmark-pdf"></i> Descargar PDF (Notificación)
                    </button>
                </div>

                <div id="documento-alimentos">
                    <div class="formato-impresion" style="max-width: 1000px; margin: auto; background-color: white; padding: 30px; border: 1px solid #ccc; font-family: Arial, sans-serif;">

                        <h4 class="text-center fw-bold border border-dark p-2 mb-0" style="background-color: #d1d1d1;">
                            NOTIFICACIÓN DE EVENTO FOLIO @(alimentos.Folio ?? "____")
                        </h4>

                        <table class="table table-bordered border-dark text-center mt-0 mb-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td style="width: 50%;">@(Model.FechaCreacion.ToString("dd/MM/yyyy"))</td>
                                    <td style="width: 50%;" class="fw-bold bg-light">FECHA DE EVENTO:</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">CLIENTE Y/O EMPRESA:</td>
                                    <td>@alimentos.FechaEvento</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold fs-5 text-uppercase">@alimentos.ClienteEmpresa</td>
                                    <td class="p-0">
                                        <table class="table table-borderless m-0 h-100">
                                            <tr>
                                                <td style="width: 30%; border-right: 1px solid black;" class="fw-bold bg-light">EJECUTIVO:</td>
                                                <td>@alimentos.Ejecutivo</td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <table class="table table-bordered border-dark text-center mt-3 mb-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td style="width: 50%;" class="fw-bold bg-light">HORARIO:</td>
                                    <td style="width: 50%;"></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold fs-5">@alimentos.ConceptoServicio</td>
                                    <td>
                                        <div class="fw-bold fs-5">@alimentos.Horario</div>
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">LUGAR:</td>
                                    <td class="fw-bold bg-light">MONTAJE:</td>
                                </tr>
                                <tr>
                                    <td>@alimentos.Lugar</td>
                                    <td>@alimentos.Montaje</td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="fw-bold text-center border border-dark border-bottom-0 mt-3" style="background-color: #d1d1d1;">COSTOS:</div>
                        <table class="table table-bordered border-dark text-center mb-0" style="font-size: 0.85rem;">
                            <thead style="background-color: #ffff00;">
                                <tr>
                                    <th style="width: 15%;" class="bg-light">CONCEPTO:</th>
                                    <th style="width: 17%;"></th>
                                    <th style="width: 17%;"></th>
                                    <th style="width: 17%;"></th>
                                    <th style="width: 17%;"></th>
                                    <th style="width: 17%;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold bg-light">PRECIO:</td>
                                    <td>$ @(alimentos.Precio?.ToString("0.00") ?? "-")</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">IVA:</td>
                                    <td>$ @(alimentos.Iva?.ToString("0.00") ?? "-")</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">SERVICIO:</td>
                                    <td>$ @(alimentos.Servicio?.ToString("0.00") ?? "-")</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">SUBTOTAL:</td>
                                    <td>$ @(alimentos.Subtotal?.ToString("0.00") ?? "-")</td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">NO. PAX:</td>
                                    <td class="fw-bold">@alimentos.NoPax</td>
                                    <td class="fw-bold">@alimentos.NoPax2</td>
                                    <td class="fw-bold">@alimentos.NoPax3</td>
                                    <td class="fw-bold">@alimentos.NoPax4</td>
                                    <td class="fw-bold">@alimentos.NoPax5</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">NO. DÍAS:</td>
                                    <td>@alimentos.NoDias</td>
                                    <td>@alimentos.NoDias2</td>
                                    <td>@alimentos.NoDias3</td>
                                    <td>@alimentos.NoDias4</td>
                                    <td>@alimentos.NoDias5</td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="fw-bold bg-light text-end pe-3">TOTAL:</td>
                                    <td class="fw-bold fs-6">$ @(alimentos.Total?.ToString("0.00") ?? "-")</td>
                                    <td colspan="3"></td>
                                </tr>
                            </tbody>
                        </table>

                        <table class="table table-bordered border-dark text-center mt-0 mb-0 border-top-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td style="width: 50%;" class="fw-bold bg-light">CORTESÍAS:</td>
                                    <td style="width: 50%;" class="fw-bold bg-light">PAGO:</td>
                                </tr>
                                <tr>
                                    <td class="p-3 fw-bold text-uppercase">@alimentos.Cortesias</td>
                                    <td class="p-3 fw-bold text-decoration-underline">@alimentos.Pago</td>
                                </tr>
                                <tr>
                                    <td rowspan="2" class="p-4 align-middle fw-bold text-start" style="color: black; white-space: pre-wrap;">@alimentos.NotasAdicionales</td>
                                    <td class="fw-bold bg-light text-start ps-3 border-bottom-0">OBSERVACIONES:</td>
                                </tr>
                                <tr>
                                    <td class="p-4 border-top-0 fw-bold fs-5 text-uppercase" style="background-color: #ffff00; color: black;">@alimentos.Observaciones</td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- SECCIÓN QUE ESTABA OCULTA EN EL DETALLE -->
                        <table class="table table-bordered border-dark text-center mt-0 mb-0 border-top-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td class="fw-bold bg-light align-middle" style="width: 50%;">
                                        <div class="d-flex align-items-center justify-content-center">
                                            ESTACIONAMIENTO: <span class="ms-2 fw-bold text-dark">@alimentos.Estacionamiento</span>
                                        </div>
                                    </td>
                                    <td class="p-0" style="width: 50%;">
                                        <table class="table table-borderless m-0 h-100 w-100">
                                            <tr>
                                                <td class="fw-bold bg-light border-bottom border-end border-dark" style="width: 50%;">PREPARAR:</td>
                                                <td class="p-0 border-bottom border-dark align-middle fw-bold" style="width: 50%;">@alimentos.Preparar</td>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold bg-light border-end border-dark">GARANTÍA:</td>
                                                <td class="p-0 align-middle fw-bold">@alimentos.Garantia</td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="fw-bold bg-light fs-6 text-start ps-3">MENÚS:</td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="p-4 fw-bold text-uppercase text-center" style="white-space: pre-wrap;">@alimentos.Menus</td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-secondary text-center shadow-sm p-5 mt-4 rounded-4">
                    <h4><i class="bi bi-info-circle text-secondary"></i> Sin Formato de Alimentos</h4>
                    <p class="fs-5">Este aviso no cuenta con una Notificación de Eventos (Alimentos) vinculada.</p>
                </div>
            }
        </div>

        <!-- ============================================== -->
        <!-- PESTAÑA 3: MEMORÁNDUM                          -->
        <!-- ============================================== -->
        <div class="tab-pane fade" id="memorandum-panel" role="tabpanel">
            @if (esMemorandum)
            {
                <div class="text-end mb-3">
                    <button onclick="descargarPDF('documento-memorandum', 'Memorandum_@Model.Folio')" class="btn btn-danger shadow-sm">
                        <i class="bi bi-file-earmark-pdf"></i> Descargar PDF (Memorándum)
                    </button>
                </div>

                <div id="documento-memorandum">
                    <div class="formato-impresion" style="max-width: 800px; margin: auto; background-color: white; padding: 40px; font-family: Arial, sans-serif;">

                        <h3 class="text-center fw-bold mb-5" style="letter-spacing: 5px;">M E M O R A N D U M</h3>

                        <div class="mb-4" style="line-height: 1.2;">
                            <div class="d-flex"><div style="width: 80px;" class="fw-bold">Para:</div><div>@memo.Para</div></div>
                            <div class="d-flex"><div style="width: 80px;" class="fw-bold">De:</div><div>@memo.De</div></div>
                            <div class="d-flex"><div style="width: 80px;" class="fw-bold">Fecha:</div><div>@memo.FechaMemorandum</div></div>
                            <div class="d-flex"><div style="width: 80px;" class="fw-bold">Asunto:</div><div class="fw-bold">“@(memo.Asunto?.ToUpper())”</div></div>
                        </div>

                        <p class="text-justify mb-4" style="font-size: 0.95rem;">@memo.Saludo</p>

                        <div class="mb-4 fw-bold" style="line-height: 1.2;">
                            <div>IN: @memo.CheckIn</div>
                            <div>OUT: @memo.CheckOut</div>
                            <div>GARANTIA: @memo.Garantia</div>
                            <div class="mt-3">Nombre: @memo.NombreHuesped</div>
                        </div>

                        <table class="table table-bordered border-dark text-center align-middle mb-2" style="font-size: 0.85rem;">
                            <thead class="fw-bold">
                                <tr>
                                    <th style="width: 30%; padding: 5px;">TIPO DE HABITACION</th>
                                    <th style="width: 15%; padding: 5px;">CANTIDAD</th>
                                    <th style="width: 15%; padding: 5px;">NOCHES</th>
                                    <th style="width: 20%; padding: 5px;">COSTO</th>
                                    <th style="width: 20%; padding: 5px;">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody>
                                @for (int i = 1; i <= 4; i++)
                                {
                                    var concepto = typeof(WestBesternoficialya.Models.Memorandum).GetProperty("Concepto" + i)?.GetValue(memo)?.ToString();
                                    var cantidad = typeof(WestBesternoficialya.Models.Memorandum).GetProperty("Cantidad" + i)?.GetValue(memo)?.ToString();
                                    var noches = typeof(WestBesternoficialya.Models.Memorandum).GetProperty("Noches" + i)?.GetValue(memo)?.ToString();
                                    var costo = (decimal?)(typeof(WestBesternoficialya.Models.Memorandum).GetProperty("Costo" + i)?.GetValue(memo));
                                    var total = (decimal?)(typeof(WestBesternoficialya.Models.Memorandum).GetProperty("Total" + i)?.GetValue(memo));

                                    if (!string.IsNullOrEmpty(concepto))
                                    {
                                        <tr>
                                            <td class="fw-bold">@concepto</td>
                                            <td>@cantidad</td>
                                            <td>@noches</td>
                                            <td>@(costo > 0 ? costo?.ToString("C") : "")</td>
                                            <td>@(total > 0 ? total?.ToString("C") : "")</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>

                        <div class="text-end fw-bold mb-5" style="font-size: 1.1rem;">
                            TOTAL @(memo.GranTotal?.ToString("C") ?? "$ 0.00")
                        </div>

                        <div class="mb-5" style="font-size: 0.9rem; text-align: justify;">
                            @if (!string.IsNullOrEmpty(memo.InstruccionesRecepcion))
                            {
                                <p class="mb-3"><span class="fw-bold">RECEPCION:</span> @memo.InstruccionesRecepcion</p>
                            }
                            @if (!string.IsNullOrEmpty(memo.InstruccionesRestaurante))
                            {
                                <p class="mb-3"><span class="fw-bold">RESTAURANTE:</span> @memo.InstruccionesRestaurante</p>
                            }
                            @if (!string.IsNullOrEmpty(memo.InstruccionesAmaLlaves))
                            {
                                <p class="mb-3"><span class="fw-bold">AMA DE LLAVES Y MTTO:</span> @memo.InstruccionesAmaLlaves</p>
                            }
                        </div>

                        <div class="text-center fw-bold mt-5" style="font-size: 0.85rem;">
                            @memo.NotaFinal
                        </div>
                    </div>
                </div>
            }
            else
            {
                <div class="alert alert-secondary text-center shadow-sm p-5 mt-4 rounded-4">
                    <h4><i class="bi bi-info-circle text-secondary"></i> Sin Memorándum</h4>
                    <p class="fs-5">Este aviso no cuenta con un formato de Memorándum adjunto.</p>
                </div>
            }
        </div>

    </div>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }
    
    /* ESTA REGLA EVITA QUE EL PDF CORTE LAS TABLAS O LAS FILAS A LA MITAD */
    table, tr, td, th, tbody, thead, tfoot {
        page-break-inside: avoid !important;
    }
</style>

@* LIBRERÍA Y SCRIPT MÁGICO PARA DESCARGAR PDFs PERFECTOS *@
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<script>
    function descargarPDF(divId, nombreArchivo) {
    var elemento = document.getElementById(divId);

    // 1. Guardamos tu diseño original tal y como lo hiciste
    var estiloOriginal = elemento.getAttribute("style");

    // 2. Encogemos el formato y quitamos bordes visuales para el PDF
    elemento.style.maxWidth = "800px";
    elemento.style.padding = "20px";
    elemento.style.margin = "0";
    elemento.style.border = "none";

    var opciones = {
    margin:       [0.5, 0.5, 0.5, 0.5], // Margen: Arriba, Derecha, Abajo, Izquierda (Para que no quede pegado al borde del papel)
    filename:     nombreArchivo + '.pdf',
    image:        { type: 'jpeg', quality: 0.98 },
            
    // scrollY: 0 es el truco para que nunca empiece a imprimir desde la mitad de la hoja
    html2canvas:  { scale: 2, useCORS: true, scrollY: 0 },
            
    jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' },
            
    // pagebreak le dice al sistema: "Prohibido romper las filas de la tabla (tr) si cambia de página"
    pagebreak:    { mode: ['avoid-all', 'css', 'legacy'] }
    };

    // 3. Tomamos la "foto", generamos el PDF y lo descargamos
    html2pdf().set(opciones).from(elemento).save().then(function() {
    // 4. Una vez descargado, regresamos tu diseño original a la pantalla
    elemento.setAttribute("style", estiloOriginal);
    });
    }
</script>