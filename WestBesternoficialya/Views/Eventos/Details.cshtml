@model WestBesternoficialya.Models.Evento

@{
    ViewData["Title"] = "Detalles del Aviso y Formatos";
    bool esInstructivoGrupo = !string.IsNullOrEmpty(Model.Grupo) || !string.IsNullOrEmpty(Model.Folio) || Model.Fecha != null;

    // ==========================================
    // CÁLCULOS DEL INSTRUCTIVO (FORMATO 1)
    // ==========================================
    int habS = Model.Sencillas ?? 0;
    int habD = Model.Dobles ?? 0;
    int habT = Model.Triples ?? 0;
    int habC = Model.Cuadruples ?? 0;
    int habCor = Model.CortesiasHabitacion ?? 0;

    int nocS = Model.NochesSencilla ?? 0;
    int nocD = Model.NochesDoble ?? 0;
    int nocT = Model.NochesTriple ?? 0;
    int nocC = Model.NochesCuadruple ?? 0;
    int nocCor = Model.NochesCortesia ?? 0;

    int paxS = habS * 1;
    int paxD = habD * 2;
    int paxT = habT * 3;
    int paxC = habC * 4;
    int paxCor = 0;

    decimal totS = habS * (Model.TarifaSencilla ?? 0) * nocS;
    decimal totD = habD * (Model.TarifaDoble ?? 0) * nocD;
    decimal totT = habT * (Model.TarifaTriple ?? 0) * nocT;
    decimal totC = habC * (Model.TarifaCuadruple ?? 0) * nocC;
    decimal totCor = habCor * (Model.TarifaCortesia ?? 0) * nocCor;

    int totalHabs = habS + habD + habT + habC + habCor;
    int totalPax = paxS + paxD + paxT + paxC + paxCor;

    decimal sumaHospedaje = totS + totD + totT + totC + totCor;
    decimal totalAlimentos = Model.CostoAlimentos ?? 0;
    decimal totalPropinas = Model.CostoPropinas ?? 0;
    decimal totalEvento = Model.TotalEvento ?? (sumaHospedaje + totalAlimentos + totalPropinas);

    // Extraemos el segundo formato de la charola
    var alimentos = ViewBag.Alimentos as WestBesternoficialya.Models.NotificacionEvento;
}

<div class="container mt-4 mb-5">

    <div class="d-print-none mb-4 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver al Tablero</a>
        <div>
            <a asp-action="Firmar" asp-route-id="@Model.Id" class="btn btn-success ms-2">
                <i class="bi bi-check-circle"></i> Marcar de Enterado
            </a>
        </div>
    </div>

    <ul class="nav nav-tabs mb-4" id="formatosTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold fs-5 text-dark" id="instructivo-tab" data-bs-toggle="tab" data-bs-target="#instructivo-panel" type="button" role="tab">
                📄 1. Instructivo de Grupo
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold fs-5 text-dark" id="alimentos-tab" data-bs-toggle="tab" data-bs-target="#alimentos-panel" type="button" role="tab">
                🍽️ 2. Notificación de Evento
            </button>
        </li>
    </ul>

    <div class="tab-content" id="formatosTabContent">

        <div class="tab-pane fade show active" id="instructivo-panel" role="tabpanel">
            <div class="text-end mb-3">
                @if (esInstructivoGrupo)
                {
                    <button onclick="descargarPDF('documento-instructivo', 'Instructivo_@Model.Folio')" class="btn btn-danger shadow-sm">
                        <i class="bi bi-file-earmark-pdf"></i> Descargar PDF (Instructivo)
                    </button>
                }
            </div>

            <div id="documento-instructivo">
                @if (!esInstructivoGrupo)
                {
                    <div class="card shadow border-primary">
                        <div class="card-header bg-primary text-white">
                            <h4 class="mb-0">@Model.Titulo</h4>
                        </div>
                        <div class="card-body p-4">
