@model WestBesternoficialya.Models.Evento

@{
    ViewData["Title"] = "Detalles del Aviso";
    bool esInstructivoGrupo = !string.IsNullOrEmpty(Model.Grupo) || !string.IsNullOrEmpty(Model.Folio) || Model.Fecha != null;

    // ==========================================
    // CÁLCULOS INDIVIDUALES DE FILA (EXCEL CLONE)
    // ==========================================
    int habS = Model.Sencillas ?? 0;
    int habD = Model.Dobles ?? 0;
    int habT = Model.Triples ?? 0;
    int habC = Model.Cuadruples ?? 0;
    int habCor = Model.CortesiasHabitacion ?? 0;

    int nocS = Model.NochesSencilla ?? 0;
    int nocD = Model.NochesDoble ?? 0;
    int nocT = Model.NochesTriple ?? 0;
    int nocC = Model.NochesCuadruple ?? 0;
    int nocCor = Model.NochesCortesia ?? 0;

    int paxS = habS * 1;
    int paxD = habD * 2;
    int paxT = habT * 3;
    int paxC = habC * 4;
    int paxCor = 0;

    decimal totS = habS * (Model.TarifaSencilla ?? 0) * nocS;
    decimal totD = habD * (Model.TarifaDoble ?? 0) * nocD;
    decimal totT = habT * (Model.TarifaTriple ?? 0) * nocT;
    decimal totC = habC * (Model.TarifaCuadruple ?? 0) * nocC;
    decimal totCor = habCor * (Model.TarifaCortesia ?? 0) * nocCor;

    int totalHabs = habS + habD + habT + habC + habCor;
    int totalPax = paxS + paxD + paxT + paxC + paxCor;
    
    decimal sumaHospedaje = totS + totD + totT + totC + totCor;
    decimal totalAlimentos = Model.CostoAlimentos ?? 0;
    decimal totalPropinas = Model.CostoPropinas ?? 0;
    decimal totalEvento = Model.TotalEvento ?? (sumaHospedaje + totalAlimentos + totalPropinas);
}

<div class="container mt-4 mb-5">
    
    <div class="d-print-none mb-4 d-flex justify-content-between">
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver al Tablero</a>
        <div>
            @if (esInstructivoGrupo)
            {
                <button onclick="window.print()" class="btn btn-dark"><i class="bi bi-printer"></i> Imprimir Formato</button>
            }
            <a asp-action="Firmar" asp-route-id="@Model.Id" class="btn btn-success ms-2">Marcar de Enterado</a>
        </div>
    </div>

    @if (!esInstructivoGrupo)
    {
        <div class="card shadow border-primary">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">@Model.Titulo</h4>
            </div>
            <div class="card-body p-4">
                <h5 class="text-primary mb-3"><i class="bi bi-megaphone"></i> Comunicado General</h5>
                <p class="fs-5" style="white-space: pre-wrap;">@Model.DetallesLogistica</p>
                <hr class="mt-5" />
                <div class="text-muted small">
                    <p class="mb-0"><strong>Publicado por:</strong> @(Model.Creador ?? "Administrador")</p>
                    <p class="mb-0"><strong>Fecha de Publicación:</strong> @Model.FechaCreacion.ToString("dd/MM/yyyy hh:mm tt")</p>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="formato-impresion" style="max-width: 1000px; margin: auto; background-color: white; padding: 30px; border: 1px solid #ccc; font-family: Arial, sans-serif;">
            
            <div class="p-3 mb-3 border border-dark" style="background-color: #e2e3e5;">
                <h2 class="text-center fw-bold mb-3" style="letter-spacing: 2px;">HOTEL SAN PEDRO</h2>
                <div class="d-flex justify-content-between fw-bold fs-5">
                    <div>INSTRUCTIVO DE GRUPO</div>
                    <div>FOLIO @(Model.Folio ?? "____")</div>
                </div>
            </div>

            <table class="table table-bordered border-dark mt-0" style="font-size: 0.9rem;">
                <tr>
                    <td style="width: 15%;" class="bg-light"><strong>Fecha:</strong></td>
                    <td style="width: 35%;">@(Model.Fecha?.ToString("dd-MMM-yy") ?? "---")</td>
                    <td style="width: 15%;" class="bg-light"><strong>Grupo:</strong></td>
                    <td style="width: 35%;" class="fw-bold text-uppercase">@(Model.Grupo ?? "---")</td>
                </tr>
                <tr>
                    <td class="bg-light"><strong>Agencia:</strong></td>
                    <td>@Model.Agencia</td>
                    <td class="bg-light"><strong>Tipo Grupo:</strong></td>
                    <td>@Model.TipoGrupo</td>
                </tr>
                <tr>
                    <td class="bg-light"><strong>Dirección:</strong></td>
                    <td>@Model.Direccion</td>
                    <td class="bg-light"><strong>Teléfono:</strong></td>
                    <td>@Model.Telefono</td>
                </tr>
                <tr>
                    <td class="bg-light"><strong>Coordinador:</strong></td>
                    <td>@Model.Coordinador</td>
                    <td class="bg-light"><strong>R.F.C.:</strong></td>
                    <td>@Model.Rfc</td>
                </tr>
                <tr>
                    <td class="bg-light"><strong>Ejecutivo:</strong></td>
                    <td>@Model.Ejecutivo</td>
                    <td class="bg-light"><strong>Ant:</strong></td>
                    <td>@Model.Ant</td>
                </tr>
                <tr>
                    <td class="bg-light"><strong>Fecha Entrada:</strong></td>
                    <td class="fw-bold">@(Model.FechaEntrada?.ToString("dd/MM/yyyy") ?? "---")</td>
                    <td class="bg-light"><strong>Fecha Salida:</strong></td>
                    <td class="fw-bold">@(Model.FechaSalida?.ToString("dd/MM/yyyy") ?? "---")</td>
                </tr>
                <tr>
                    <td colspan="2"></td>
                    <td class="bg-light"><strong>Hora Llegada:</strong></td>
                    <td>@Model.HoraLlegada</td>
                </tr>
            </table>

            <table class="table table-bordered border-dark text-center mb-0" style="font-size: 0.85rem;">
                <thead class="bg-light">
                    <tr class="align-middle">
                        <th style="width: 15%;"></th>
                        <th style="width: 15%;">TARIFAS</th>
                        <th style="width: 14%;">N° DE HAB</th>
                        <th style="width: 10%;">PAX</th>
                        <th style="width: 10%;">NOCHES</th>
                        <th style="width: 20%;">TOTAL</th>
                        <th style="width: 16%;">PROPINA</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="text-center fw-bold">SENCILLA</td>
                        <td>@(Model.TarifaSencilla != null ? Model.TarifaSencilla?.ToString("C") : "$ -")</td>
                        <td>@(habS > 0 ? habS.ToString() : "-")</td>
                        <td>@(paxS > 0 ? paxS.ToString() : "-")</td>
                        <td>@(nocS > 0 ? nocS.ToString() : "-")</td>
                        <td>@(totS > 0 ? totS.ToString("C") : "$ -")</td>
                        <td>@(string.IsNullOrEmpty(Model.PropinaSencilla) ? "-" : Model.PropinaSencilla)</td>
                    </tr>
                    <tr>
                        <td class="text-center fw-bold">DOBLE</td>
                        <td>@(Model.TarifaDoble != null ? Model.TarifaDoble?.ToString("C") : "$ -")</td>
                        <td>@(habD > 0 ? habD.ToString() : "-")</td>
                        <td>@(paxD > 0 ? paxD.ToString() : "-")</td>
                        <td>@(nocD > 0 ? nocD.ToString() : "-")</td>
                        <td>@(totD > 0 ? totD.ToString("C") : "$ -")</td>
                        <td>@(string.IsNullOrEmpty(Model.PropinaDoble) ? "-" : Model.PropinaDoble)</td>
                    </tr>
                    <tr>
                        <td class="text-center fw-bold">TRIPLE</td>
                        <td>@(Model.TarifaTriple != null ? Model.TarifaTriple?.ToString("C") : "$ -")</td>
                        <td>@(habT > 0 ? habT.ToString() : "-")</td>
                        <td>@(paxT > 0 ? paxT.ToString() : "-")</td>
                        <td>@(nocT > 0 ? nocT.ToString() : "-")</td>
                        <td>@(totT > 0 ? totT.ToString("C") : "$ -")</td>
                        <td>@(string.IsNullOrEmpty(Model.PropinaTriple) ? "-" : Model.PropinaTriple)</td>
                    </tr>
                    <tr>
                        <td class="text-center fw-bold">CUÁDRUPLE</td>
                        <td>@(Model.TarifaCuadruple != null ? Model.TarifaCuadruple?.ToString("C") : "$ -")</td>
                        <td>@(habC > 0 ? habC.ToString() : "-")</td>
                        <td>@(paxC > 0 ? paxC.ToString() : "-")</td>
                        <td>@(nocC > 0 ? nocC.ToString() : "-")</td>
                        <td>@(totC > 0 ? totC.ToString("C") : "$ -")</td>
                        <td>@(string.IsNullOrEmpty(Model.PropinaCuadruple) ? "-" : Model.PropinaCuadruple)</td>
                    </tr>
                    <tr>
                        <td class="text-center fw-bold">CORTESÍA</td>
                        <td>@(Model.TarifaCortesia != null ? Model.TarifaCortesia?.ToString("C") : "$ -")</td>
                        <td>@(habCor > 0 ? habCor.ToString() : "-")</td>
                        <td>@(paxCor > 0 ? paxCor.ToString() : "-")</td>
                        <td>@(nocCor > 0 ? nocCor.ToString() : "-")</td>
                        <td>@(totCor > 0 ? totCor.ToString("C") : "$ -")</td>
                        <td>@(string.IsNullOrEmpty(Model.PropinaCortesia) ? "-" : Model.PropinaCortesia)</td>
                    </tr>
                    <tr class="fw-bold">
                        <td class="border-0"></td>
                        <td class="border-0"></td>
                        <td class="border-dark">@(totalHabs > 0 ? totalHabs.ToString() : "-")</td>
                        <td class="border-dark">@(totalPax > 0 ? totalPax.ToString() : "-")</td>
                        <td class="text-center bg-light border-dark">HOSPEDAJE:</td>
                        <td class="text-end border-dark">@sumaHospedaje.ToString("C")</td>
                        <td class="text-end border-dark">-</td>
                    </tr>
                    <tr class="fw-bold">
                        <td colspan="4" class="border-0"></td>
                        <td class="text-center bg-light border-dark">ALIMENTOS:</td>
                        <td class="text-end border-dark">@totalAlimentos.ToString("C")</td>
                        <td class="border-0"></td>
                    </tr>
                    <tr class="fw-bold">
                        <td colspan="4" class="border-0"></td>
                        <td class="text-center bg-light border-dark">PROPINAS:</td>
                        <td class="text-end border-dark">@totalPropinas.ToString("C")</td>
                        <td class="border-0"></td>
                    </tr>
                    <tr class="fw-bold">
                        <td colspan="4" class="border-0"></td>
                        <td class="text-center bg-light border-dark">TOTAL<br/>EVENTO:</td>
                        <td class="text-end border-dark">@totalEvento.ToString("C")</td>
                        <td class="border-0"></td>
                    </tr>
                </tbody>
            </table>

            <table class="table table-bordered border-dark mt-3" style="font-size: 0.9rem;">
                <tr class="bg-light">
                    <td colspan="2" class="fw-bold">NO. DE RESERVACIÓN: <span class="bg-white px-3 border border-dark ms-2">@Model.NumeroReservacion</span></td>
                </tr>
                <tr>
                    <td style="width: 25%;" class="bg-light"><strong>Cta. Maestra:</strong></td>
                    <td>@Model.CuentaMaestra</td>
                </tr>
                <tr>
                    <td class="bg-light"><strong>Cta. Individual:</strong></td>
                    <td>@Model.CuentasIndividuales</td>
                </tr>
            </table>

            <table class="table table-bordered border-dark mb-0" style="font-size: 0.85rem;">
                <tr>
                    <td style="width: 20%; vertical-align: top;" class="bg-white">
                        <strong class="bg-light px-2 py-1 border border-dark d-inline-block mb-2">OBSERVACIONES:</strong><br />
                    </td>
                    <td style="width: 80%; background-color: #cfe2ff; color: #084298; text-align: center; vertical-align: middle;" class="fw-bold fs-4 px-4">
                        @(string.IsNullOrEmpty(Model.Observaciones) ? "\"BRINDAR EL SERVICIO QUE NOS CARACTERIZA\"" : $"\"{Model.Observaciones.ToUpper()}\"")
                    </td>
                </tr>
            </table>

            <table class="table table-bordered border-dark mt-0 border-top-0" style="font-size: 0.85rem;">
                <tr><td style="width: 20%;" class="bg-light border-top-0"><strong>CORTESÍAS:</strong></td><td class="border-top-0">@Model.CortesiasExtras</td></tr>
                <tr><td class="bg-light"><strong>ANTICIPO:</strong></td><td>@Model.Anticipo</td></tr>
                <tr><td class="bg-light"><strong>FACTURAR A:</strong></td><td>@Model.FacturarA</td></tr>
                <tr><td class="bg-light"><strong>DOMICILIO:</strong></td><td>@Model.DomicilioFacturacion</td></tr>
                <tr><td class="bg-light"><strong>R.F.C.:</strong></td><td>@Model.RfcFacturacion</td></tr>
                <tr><td class="bg-light"><strong>TELÉFONO FACT.:</strong></td><td>@Model.TelefonoFacturacion</td></tr>
                <tr><td class="bg-light"><strong>TELÉFONO GUÍA:</strong></td><td>@Model.Guia</td></tr>
                <tr><td class="bg-light"><strong>DESPERTADOR:</strong></td><td>@Model.Despertador</td></tr>
                <tr><td class="bg-light"><strong>ALIMENTOS:</strong></td><td>@Model.NotasAlimentos</td></tr>
                <tr><td class="bg-light"><strong>EQUIPAJE:</strong></td><td>@Model.Equipaje</td></tr>
            </table>

        </div>
    }
</div>

<style>
    @@media print {
        body { background-color: white !important; }
        .container { border: none !important; box-shadow: none !important; width: 100% !important; max-width: none !important; margin: 0 !important; padding: 0 !important;}
        .btn, .d-print-none, header, footer, nav { display: none !important; }
        * { -webkit-print-color-adjust: exact !important; color-adjust: exact !important; }
        .formato-impresion { border: none !important; padding: 0 !important; }
    }
    .bg-light { background-color: #f8f9fa !important; font-weight: bold; }
</style>