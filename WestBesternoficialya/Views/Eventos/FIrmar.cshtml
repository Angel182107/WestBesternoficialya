@model WestBesternoficialya.Models.Evento

<div class="container mt-4">
    <h2>Firma Electrónica de Enterado</h2>
    <hr />

    <div class="alert alert-info">
        <h4 class="alert-heading">Aviso: @Model.Titulo</h4>
        <p>@Model.DetallesLogistica</p>
    </div>

    <div class="row">
        <div class="col-md-6">
            <form asp-action="GuardarFirma" method="post">
                <input type="hidden" name="eventoId" value="@Model.Id" />

                <div class="alert alert-warning mb-3">
                    <i class="bi bi-shield-lock-fill"></i> <strong>Aviso de Seguridad:</strong>
                    Tu firma quedará registrada automáticamente con tu usuario actual (<strong>@User.Identity.Name</strong>) y la hora exacta del sistema.
                </div>

                <button type="submit" class="btn btn-success">
                    <i class="bi bi-pen"></i> Firmar de enterado
                </button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>