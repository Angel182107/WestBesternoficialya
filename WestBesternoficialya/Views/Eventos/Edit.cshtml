@model WestBesternoficialya.Models.Evento

@{
    ViewData["Title"] = "Editar Aviso";

    // 1. Magia para separar el texto de los archivos
    string textoAviso = Model.DetallesLogistica ?? "";
    string archivosAdjuntos = "";

    if (textoAviso.Contains("===ARCHIVOS==="))
    {
        var partes = textoAviso.Split(new[] { "===ARCHIVOS===" }, StringSplitOptions.None);
        textoAviso = partes[0];
        if (partes.Length > 1) { archivosAdjuntos = partes[1]; }
    }
    else if (textoAviso.Contains("::"))
    {
        archivosAdjuntos = textoAviso; // Viejo formato (solo archivos)
        textoAviso = "";
    }
}

<div class="container mt-4 mb-5">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-secondary shadow-sm"><i class="bi bi-arrow-left"></i> Volver al Tablero</a>
        <h3 class="text-primary fw-bold m-0">✏️ Editar Aviso</h3>
    </div>

    <div class="card shadow-lg border-primary border-0 rounded-3" style="max-width: 600px; margin: auto;">
        <div class="card-header bg-primary text-white text-center py-3">
            <h4 class="mb-0"><i class="bi bi-pencil-square me-2"></i> Modificar Información</h4>
        </div>

        <div class="card-body p-4 bg-light">
            <form asp-action="Edit" asp-controller="Eventos" method="post" id="formEditEvento">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FechaCreacion" />
                <input type="hidden" asp-for="Creador" />

                <!-- 2. Aquí viaja el resultado final al servidor -->
                <input type="hidden" asp-for="DetallesLogistica" id="DetallesLogisticaFinal" />

                <!-- 3. Aquí escondemos los archivos para no perderlos -->
                <input type="hidden" id="ArchivosOcultos" value="@archivosAdjuntos" />

                <div class="mb-4">
                    <label asp-for="Titulo" class="form-label fw-bold text-primary">Título del Aviso / Grupo <span class="text-danger">*</span></label>
                    <input asp-for="Titulo" class="form-control form-control-lg border-primary shadow-sm" required />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold text-primary">Detalles del Aviso (Opcional)</label>
                    <textarea id="TextoUsuario" class="form-control border-primary shadow-sm" rows="6" placeholder="Modifica aquí las instrucciones del aviso...">@textoAviso</textarea>
                </div>

                @if (!string.IsNullOrEmpty(archivosAdjuntos))
                {
                    <div class="alert alert-info shadow-sm rounded-3">
                        <i class="bi bi-info-circle-fill me-2 fs-5"></i>
                        <strong>Archivos protegidos:</strong> Este aviso contiene documentos. Puedes editar el título y el texto libremente, pero si necesitas cambiar o subir nuevos archivos, deberás borrar este aviso y crear uno nuevo.
                    </div>
                }

                <hr class="mt-4 mb-4" />

                <div class="text-center d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">Cancelar</a>
                    <button type="submit" class="btn btn-success btn-lg px-4 shadow-sm fw-bold">
                        <i class="bi bi-save"></i> Guardar Cambios
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // 4. Antes de enviar el formulario, volvemos a pegar todo
        document.getElementById('formEditEvento').addEventListener('submit', function (e) {
            let texto = document.getElementById('TextoUsuario').value;
            let archivos = document.getElementById('ArchivosOcultos').value;

            let resultadoFinal = texto;

            // Si hay archivos, le pegamos el separador mágico
            if (archivos !== "") {
                resultadoFinal = texto + "===ARCHIVOS===" + archivos;
            }

            // Metemos todo en el campo oculto que sí viaja a la Base de Datos
            document.getElementById('DetallesLogisticaFinal').value = resultadoFinal;
        });
    </script>
}