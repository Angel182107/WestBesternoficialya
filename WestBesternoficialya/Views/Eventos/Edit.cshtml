@model WestBesternoficialya.Models.Evento
@{
    ViewData["Title"] = "Editar Formatos";
    bool esInstructivoGrupo = !string.IsNullOrEmpty(Model.Grupo) || !string.IsNullOrEmpty(Model.Folio) || Model.Fecha != null;
    var alimentos = ViewBag.Alimentos as WestBesternoficialya.Models.NotificacionEvento;
}

<div class="container mt-4 mb-5">
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Volver al Tablero</a>
        <h3 class="text-primary fw-bold m-0">✏️ Editar Formatos</h3>
    </div>

    <!-- PESTAÑAS -->
    <ul class="nav nav-tabs mb-4" id="formatosTab" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active fw-bold fs-5 text-dark" data-bs-toggle="tab" data-bs-target="#instructivo-panel" type="button" role="tab">
                📄 1. Instructivo / Aviso
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link fw-bold fs-5 text-dark" data-bs-toggle="tab" data-bs-target="#alimentos-panel" type="button" role="tab">
                🍽️ 2. Notificación de Evento
            </button>
        </li>
    </ul>

    <div class="tab-content">
        <!-- ****************************************** -->
        <!-- ARCHIVO 1: AVISO O INSTRUCTIVO -->
        <!-- ****************************************** -->
        <div class="tab-pane fade show active" id="instructivo-panel" role="tabpanel">
            <form asp-action="Edit" asp-controller="Eventos" method="post">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="FechaCreacion" />
                <input type="hidden" asp-for="Creador" />
                @if (esInstructivoGrupo)
                {
                    <input type="hidden" asp-for="Titulo" />
                }

                @if (!esInstructivoGrupo)
                {
                    <div class="card shadow border-primary">
                        <div class="card-header bg-primary text-white"><h4 class="mb-0">Editar Aviso General</h4></div>
                        <div class="card-body p-4">
                            <h5 class="text-primary mb-2"><i class="bi bi-megaphone"></i> Título del Aviso</h5>
                            <input asp-for="Titulo" class="form-control border-primary mb-4" required />

                            <h5 class="text-primary mb-2">Comunicado / Detalles</h5>
                            <textarea asp-for="DetallesLogistica" class="form-control border-primary" rows="6"></textarea>
                        </div>
                    </div>
                }
                else
                {
                    <div class="formato-impresion shadow-sm" style="max-width: 1000px; margin: auto; background-color: white; padding: 30px; border: 1px solid #ccc; font-family: Arial, sans-serif;">
                        <div class="p-3 mb-3 border border-dark" style="background-color: #e2e3e5;">
                            <h2 class="text-center fw-bold mb-3" style="letter-spacing: 2px;">HOTEL SAN PEDRO</h2>
                            <div class="d-flex justify-content-between fw-bold fs-5 align-items-center">
                                <div>INSTRUCTIVO DE GRUPO</div>
                                <div class="d-flex align-items-center">FOLIO <input asp-for="Folio" class="form-control form-control-sm ms-2 w-auto border-dark" /></div>
                            </div>
                        </div>

                        <table class="table table-bordered border-dark mt-0" style="font-size: 0.9rem;">
                            <tr>
                                <td style="width: 15%;" class="bg-light"><strong>Fecha:</strong></td>
                                <td style="width: 35%;"><input asp-for="Fecha" type="date" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                                <td style="width: 15%;" class="bg-light"><strong>Grupo:</strong></td>
                                <td style="width: 35%;"><input asp-for="Grupo" class="form-control form-control-sm border-0 bg-transparent fw-bold text-uppercase w-100" /></td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Agencia:</strong></td>
                                <td><input asp-for="Agencia" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                                <td class="bg-light"><strong>Tipo Grupo:</strong></td>
                                <td><input asp-for="TipoGrupo" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Dirección:</strong></td>
                                <td><input asp-for="Direccion" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                                <td class="bg-light"><strong>Teléfono:</strong></td>
                                <td><input asp-for="Telefono" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Coordinador:</strong></td>
                                <td><input asp-for="Coordinador" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                                <td class="bg-light"><strong>R.F.C.:</strong></td>
                                <td><input asp-for="Rfc" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Ejecutivo:</strong></td>
                                <td><input asp-for="Ejecutivo" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                                <td class="bg-light"><strong>Ant:</strong></td>
                                <td><input asp-for="Ant" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Fecha Entrada:</strong></td>
                                <td><input asp-for="FechaEntrada" type="date" class="form-control form-control-sm border-0 bg-transparent fw-bold w-100" /></td>
                                <td class="bg-light"><strong>Fecha Salida:</strong></td>
                                <td><input asp-for="FechaSalida" type="date" class="form-control form-control-sm border-0 bg-transparent fw-bold w-100" /></td>
                            </tr>
                            <tr>
                                <td colspan="2"></td>
                                <td class="bg-light"><strong>Hora Llegada:</strong></td>
                                <td><input asp-for="HoraLlegada" type="time" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                            </tr>
                        </table>

                        <table class="table table-bordered border-dark text-center mb-0" style="font-size: 0.85rem;">
                            <thead class="bg-light">
                                <tr class="align-middle">
                                    <th style="width: 15%;"></th>
                                    <th style="width: 15%;">TARIFAS</th>
                                    <th style="width: 14%;">N° DE HAB</th>
                                    <th style="width: 10%;"></th>
                                    <th style="width: 10%;">NOCHES</th>
                                    <th style="width: 20%;">TOTAL (Finanzas)</th>
                                    <th style="width: 16%;">PROPINA</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="text-center fw-bold">SENCILLA</td>
                                    <td><input asp-for="TarifaSencilla" type="number" step="0.01" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="Sencillas" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td></td>
                                    <td><input asp-for="NochesSencilla" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="CostoHospedaje" placeholder="Costo Hospedaje" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="PropinaSencilla" class="form-control form-control-sm border-0 text-center" /></td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">DOBLE</td>
                                    <td><input asp-for="TarifaDoble" type="number" step="0.01" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="Dobles" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td></td>
                                    <td><input asp-for="NochesDoble" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="CostoAlimentos" placeholder="Costo Alimentos" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="PropinaDoble" class="form-control form-control-sm border-0 text-center" /></td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">TRIPLE</td>
                                    <td><input asp-for="TarifaTriple" type="number" step="0.01" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="Triples" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td></td>
                                    <td><input asp-for="NochesTriple" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="CostoPropinas" placeholder="Costo Propinas" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="PropinaTriple" class="form-control form-control-sm border-0 text-center" /></td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">CUÁDRUPLE</td>
                                    <td><input asp-for="TarifaCuadruple" type="number" step="0.01" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="Cuadruples" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td></td>
                                    <td><input asp-for="NochesCuadruple" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td class="bg-light border-dark"><strong>TOTAL EVENTO:</strong></td>
                                    <td><input asp-for="PropinaCuadruple" class="form-control form-control-sm border-0 text-center" /></td>
                                </tr>
                                <tr>
                                    <td class="text-center fw-bold">CORTESÍA</td>
                                    <td><input asp-for="TarifaCortesia" type="number" step="0.01" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td><input asp-for="CortesiasHabitacion" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td></td>
                                    <td><input asp-for="NochesCortesia" type="number" class="form-control form-control-sm border-0 text-center" /></td>
                                    <td class="border-dark"><input asp-for="TotalEvento" class="form-control form-control-sm border-0 text-center fw-bold" /></td>
                                    <td><input asp-for="PropinaCortesia" class="form-control form-control-sm border-0 text-center" /></td>
                                </tr>
                            </tbody>
                        </table>

                        <table class="table table-bordered border-dark mt-3" style="font-size: 0.9rem;">
                            <tr class="bg-light">
                                <td colspan="2" class="fw-bold d-flex align-items-center">NO. DE RESERVACIÓN: <input asp-for="NumeroReservacion" class="form-control form-control-sm ms-2 w-auto border-dark" /></td>
                            </tr>
                            <tr>
                                <td style="width: 25%;" class="bg-light"><strong>Cta. Maestra:</strong></td>
                                <td><input asp-for="CuentaMaestra" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                            </tr>
                            <tr>
                                <td class="bg-light"><strong>Cta. Individual:</strong></td>
                                <td><input asp-for="CuentasIndividuales" class="form-control form-control-sm border-0 bg-transparent w-100" /></td>
                            </tr>
                        </table>

                        <table class="table table-bordered border-dark mb-0" style="font-size: 0.85rem;">
                            <tr>
                                <td style="width: 20%; vertical-align: top;" class="bg-white">
                                    <strong class="bg-light px-2 py-1 border border-dark d-inline-block mb-2">OBSERVACIONES:</strong><br />
                                </td>
                                <td style="width: 80%; background-color: #cfe2ff;" class="p-2">
                                    <textarea asp-for="Observaciones" class="form-control border-0 bg-transparent fw-bold" rows="3" style="color: #084298;"></textarea>
                                </td>
                            </tr>
                        </table>

                        <table class="table table-bordered border-dark mt-0 border-top-0" style="font-size: 0.85rem;">
                            <tr><td style="width: 20%;" class="bg-light border-top-0"><strong>CORTESÍAS:</strong></td><td class="border-top-0"><input asp-for="CortesiasExtras" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>ANTICIPO:</strong></td><td><input asp-for="Anticipo" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>FACTURAR A:</strong></td><td><input asp-for="FacturarA" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>DOMICILIO:</strong></td><td><input asp-for="DomicilioFacturacion" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>R.F.C.:</strong></td><td><input asp-for="RfcFacturacion" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>TELÉFONO FACT.:</strong></td><td><input asp-for="TelefonoFacturacion" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>TELÉFONO GUÍA:</strong></td><td><input asp-for="Guia" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>DESPERTADOR:</strong></td><td><input asp-for="Despertador" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>ALIMENTOS (Notas):</strong></td><td><input asp-for="NotasAlimentos" class="form-control form-control-sm border-0 w-100" /></td></tr>
                            <tr><td class="bg-light"><strong>EQUIPAJE:</strong></td><td><input asp-for="Equipaje" class="form-control form-control-sm border-0 w-100" /></td></tr>
                        </table>
                    </div>
                }

                <div class="mt-4 text-center">
                    <button type="submit" class="btn btn-primary btn-lg shadow-sm"><i class="bi bi-save"></i> Guardar Cambios (Pestaña 1)</button>
                </div>
            </form>
        </div>

        <!-- ****************************************** -->
        <!-- ARCHIVO 2: NOTIFICACIÓN (ALIMENTOS) -->
        <!-- ****************************************** -->
        <div class="tab-pane fade" id="alimentos-panel" role="tabpanel">
            @if (alimentos != null)
            {
                <form asp-action="Edit" asp-controller="NotificacionesEventos" method="post">
                    <input type="hidden" name="Id" value="@alimentos.Id" />
                    <input type="hidden" name="EventoId" value="@alimentos.EventoId" />

                    <div class="formato-impresion shadow-sm" style="max-width: 1000px; margin: auto; background-color: white; padding: 30px; border: 1px solid #ccc; font-family: Arial, sans-serif;">
                        <div class="text-center fw-bold border border-dark p-2 mb-0 d-flex justify-content-center align-items-center" style="background-color: #d1d1d1;">
                            NOTIFICACIÓN DE EVENTO FOLIO <input name="Folio" value="@alimentos.Folio" class="form-control form-control-sm ms-2 w-auto border-dark text-center" />
                        </div>

                        <table class="table table-bordered border-dark text-center mt-0 mb-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td style="width: 50%;">@(Model.FechaCreacion.ToString("dd/MM/yyyy"))</td>
                                    <td style="width: 50%;" class="fw-bold bg-light">FECHA DE EVENTO:</td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">CLIENTE Y/O EMPRESA:</td>
                                    <td><input name="FechaEvento" value="@alimentos.FechaEvento" class="form-control border-0 text-center" /></td>
                                </tr>
                                <tr>
                                    <td class="p-0"><input name="ClienteEmpresa" value="@alimentos.ClienteEmpresa" class="form-control border-0 fw-bold fs-5 text-center text-uppercase" /></td>
                                    <td class="p-0">
                                        <table class="table table-borderless m-0 h-100">
                                            <tr>
                                                <td style="width: 30%; border-right: 1px solid black;" class="fw-bold bg-light">EJECUTIVO:</td>
                                                <td><input name="Ejecutivo" value="@alimentos.Ejecutivo" class="form-control border-0 text-center" /></td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <table class="table table-bordered border-dark text-center mt-3 mb-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td style="width: 50%;" class="fw-bold bg-light">HORARIO:</td>
                                    <td style="width: 50%;"></td>
                                </tr>
                                <tr>
                                    <td class="p-0"><input name="ConceptoServicio" type="text" value="@alimentos.ConceptoServicio" class="form-control border-0 fw-bold fs-5 text-center" /></td>
                                    <td class="p-0"><input name="Horario" type="time" value="@alimentos.Horario" class="form-control border-0 text-center fw-bold" /></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">LUGAR:</td>
                                    <td class="fw-bold bg-light">MONTAJE:</td>
                                </tr>
                                <tr>
                                    <td class="p-0"><input name="Lugar" value="@alimentos.Lugar" class="form-control border-0 text-center" /></td>
                                    <td class="p-0"><input name="Montaje" value="@alimentos.Montaje" class="form-control border-0 text-center" /></td>
                                </tr>
                            </tbody>
                        </table>

                        <div class="fw-bold text-center border border-dark border-bottom-0 mt-3" style="background-color: #d1d1d1;">COSTOS:</div>
                        <table class="table table-bordered border-dark text-center mb-0" style="font-size: 0.85rem;">
                            <thead style="background-color: #ffff00;">
                                <tr>
                                    <th style="width: 15%;" class="bg-light">CONCEPTO:</th>
                                    <th style="width: 17%;"></th>
                                    <th style="width: 17%;"></th>
                                    <th style="width: 17%;"></th>
                                    <th style="width: 17%;"></th>
                                    <th style="width: 17%;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold bg-light">PRECIO:</td>
                                    <td class="p-0"><input name="Precio" type="number" step="0.01" value="@alimentos.Precio" class="form-control border-0 text-center" /></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">IVA:</td>
                                    <td class="p-0"><input name="Iva" type="number" step="0.01" value="@alimentos.Iva" class="form-control border-0 text-center" /></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">SERVICIO:</td>
                                    <td class="p-0"><input name="Servicio" type="number" step="0.01" value="@alimentos.Servicio" class="form-control border-0 text-center" /></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">SUBTOTAL:</td>
                                    <td class="p-0"><input name="Subtotal" type="number" step="0.01" value="@alimentos.Subtotal" class="form-control border-0 text-center" /></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                    <td></td>
                                </tr>
                                <!-- AQUÍ ESTÁN TUS 5 CELDAS DE PAX Y DÍAS -->
                                <tr>
                                    <td class="fw-bold bg-light">NO. PAX:</td>
                                    <td class="p-0"><input name="NoPax" type="number" value="@alimentos.NoPax" class="form-control border-0 text-center fw-bold" /></td>
                                    <td class="p-0"><input name="NoPax2" type="number" class="form-control border-0 text-center fw-bold" /></td>
                                    <td class="p-0"><input name="NoPax3" type="number" class="form-control border-0 text-center fw-bold" /></td>
                                    <td class="p-0"><input name="NoPax4" type="number" class="form-control border-0 text-center fw-bold" /></td>
                                    <td class="p-0"><input name="NoPax5" type="number" class="form-control border-0 text-center fw-bold" /></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light">NO. DÍAS:</td>
                                    <td class="p-0"><input name="NoDias" type="number" value="@alimentos.NoDias" class="form-control border-0 text-center" /></td>
                                    <td class="p-0"><input name="NoDias2" type="number" class="form-control border-0 text-center" /></td>
                                    <td class="p-0"><input name="NoDias3" type="number" class="form-control border-0 text-center" /></td>
                                    <td class="p-0"><input name="NoDias4" type="number" class="form-control border-0 text-center" /></td>
                                    <td class="p-0"><input name="NoDias5" type="number" class="form-control border-0 text-center" /></td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="fw-bold bg-light text-end pe-3">TOTAL:</td>
                                    <td class="p-0"><input name="Total" type="number" step="0.01" value="@alimentos.Total" class="form-control border-0 text-center fw-bold fs-6" /></td>
                                    <td colspan="3" class="fw-bold fs-6"></td>
                                </tr>
                            </tbody>
                        </table>

                        <table class="table table-bordered border-dark text-center mt-0 mb-0 border-top-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td style="width: 50%;" class="fw-bold bg-light">CORTESÍAS:</td>
                                    <td style="width: 50%;" class="fw-bold bg-light">PAGO:</td>
                                </tr>
                                <tr>
                                    <td class="p-0"><textarea name="Cortesias" class="form-control border-0 text-center fw-bold text-uppercase" rows="2">@alimentos.Cortesias</textarea></td>
                                    <td class="p-0"><input name="Pago" value="@alimentos.Pago" class="form-control border-0 text-center fw-bold text-decoration-underline mt-2" /></td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="fw-bold bg-light text-start ps-3">OBSERVACIONES:</td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="p-0" style="background-color: #ffff00;">
                                        <textarea name="Observaciones" class="form-control border-0 text-center fw-bold fs-5" rows="3" style="background-color: transparent !important; color: #084298;">@alimentos.Observaciones</textarea>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <!-- SECCIÓN NUEVA: ESTACIONAMIENTO Y MENÚS -->
                        <table class="table table-bordered border-dark text-center mt-0 mb-0 border-top-0" style="font-size: 0.9rem;">
                            <tbody>
                                <tr>
                                    <td class="fw-bold bg-light align-middle" style="width: 50%;">
                                        <div class="d-flex align-items-center justify-content-center">
                                            ESTACIONAMIENTO:
                                            <input name="Estacionamiento" class="form-control border-0 bg-transparent ms-2 w-50 fw-bold" placeholder="..." />
                                        </div>
                                    </td>
                                    <td class="p-0" style="width: 50%;">
                                        <table class="table table-borderless m-0 h-100 w-100">
                                            <tr>
                                                <td class="fw-bold bg-light border-bottom border-end border-dark" style="width: 50%;">PREPARAR:</td>
                                                <td class="p-0 border-bottom border-dark" style="width: 50%;">
                                                    <input name="Preparar" type="number" class="form-control border-0 text-center fw-bold h-100" />
                                                </td>
                                            </tr>
                                            <tr>
                                                <td class="fw-bold bg-light border-end border-dark">GARANTÍA:</td>
                                                <td class="p-0">
                                                    <input name="Garantia" type="number" class="form-control border-0 text-center fw-bold h-100" />
                                                </td>
                                            </tr>
                                        </table>
                                    </td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="fw-bold bg-light fs-6">MENÚS:</td>
                                </tr>
                                <tr>
                                    <td colspan="2" class="p-0">
                                        <textarea name="Menus" class="form-control border-0 text-center fw-bold text-uppercase" rows="4" placeholder="Ej. CAFÉ AMERICANO O TE / FRUTA / OMELETTE..."></textarea>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>

                    <div class="mt-4 text-center">
                        <button type="submit" class="btn btn-success btn-lg shadow-sm"><i class="bi bi-save"></i> Guardar Cambios (Pestaña 2)</button>
                    </div>
                </form>
            }
            else
            {
                <div class="alert alert-warning text-center shadow-sm p-5 mt-4 rounded-4">
                    <h4><i class="bi bi-exclamation-triangle text-warning"></i> Archivo No Encontrado</h4>
                    <p class="fs-5">Este grupo aún no tiene una Notificación de Evento registrada.</p>
                    <a asp-controller="NotificacionesEventos" asp-action="Create" asp-route-eventoId="@Model.Id" class="btn btn-success fw-bold px-4 shadow mt-3">
                        <i class="bi bi-file-earmark-plus"></i> Crear Nuevo Archivo
                    </a>
                </div>
            }
        </div>
    </div>
</div>

