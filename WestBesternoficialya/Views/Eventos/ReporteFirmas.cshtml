@model IEnumerable<WestBesternoficialya.Models.AcuseRecibo>

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary fw-bold">📝 Reporte de Lectura y Firmas</h2>
        <a asp-action="Index" class="btn btn-secondary shadow-sm"><i class="bi bi-arrow-left"></i> Volver a los Avisos</a>
    </div>

    <!-- TARJETA DE RESUMEN Y BOTÓN DE DESCARGA -->
    <div class="card shadow-sm border-primary mb-4 d-print-none">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h5 class="mb-1 text-muted">Aviso / Evento:</h5>
                <h3 class="fw-bold mb-0 text-dark">@ViewBag.TituloEvento</h3>
            </div>
            <!-- Botón Mágico para Descargar el PDF -->
            <button onclick="descargarPDF('reporte-firmas-imprimir', 'Reporte_Firmas_Aviso')" class="btn btn-danger btn-lg shadow-sm fw-bold">
                <i class="bi bi-file-earmark-pdf"></i> Descargar Reporte en PDF
            </button>
        </div>
    </div>

    <!-- ======================================================== -->
    <!-- CONTENEDOR DEL REPORTE (ESTO ES LO QUE SE VUELVE PDF)    -->
    <!-- ======================================================== -->
    <div id="reporte-firmas-imprimir">
        <div class="formato-impresion shadow-sm" style="max-width: 900px; margin: auto; background-color: white; padding: 40px; border: 1px solid #ccc; font-family: Arial, sans-serif;">
            
            <div class="text-center mb-4">
                <h2 class="fw-bold" style="letter-spacing: 2px;">HOTEL SAN PEDRO</h2>
                <h4 class="fw-bold text-secondary">REPORTE DE ENTERADO Y LECTURA</h4>
                <hr style="border: 2px solid #000;" />
            </div>

            <div class="mb-4">
                <table class="table table-borderless table-sm mb-0" style="font-size: 1.05rem;">
                    <tr>
                        <td style="width: 25%;" class="fw-bold">Aviso:</td>
                        <td class="text-uppercase fw-bold border-bottom border-dark">@ViewBag.TituloEvento</td>
                    </tr>
                    <tr>
                        <td class="fw-bold">Fecha de corte:</td>
                        <td class="border-bottom border-dark">@DateTime.Now.ToString("dd/MM/yyyy hh:mm tt")</td>
                    </tr>
                    <!-- ¡AQUÍ ESTÁ EL CONTADOR DE FIRMAS! -->
                    <tr>
                        <td class="fw-bold">Total de Firmas:</td>
                        <td class="border-bottom border-dark text-primary fw-bold fs-5">
                            @(Model != null ? Model.Count() : 0) Empleado(s)
                        </td>
                    </tr>
                </table>
            </div>

            <!-- TABLA DE FIRMAS CON EL DEPARTAMENTO INCLUIDO -->
            <table class="table table-bordered border-dark table-striped text-center align-middle" style="font-size: 0.95rem;">
                <thead class="bg-light text-dark fw-bold">
                    <tr>
                        <th style="width: 5%;">#</th>
                        <th style="width: 35%;">NOMBRE DEL EMPLEADO</th>
                        <th style="width: 30%;">DEPARTAMENTO</th>
                        <th style="width: 15%;">FECHA</th>
                        <th style="width: 15%;">HORA</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int contador = 1;
                        foreach (var acuse in Model)
                        {
                            <tr>
                                <td class="fw-bold">@contador</td>
                                <td class="text-start fw-bold text-uppercase">@acuse.Usuario.NombreCompleto</td>
                                <td class="fw-bold text-uppercase" style="color: #084298;">@(acuse.DepartamentoFirma ?? "SIN DEPARTAMENTO")</td>
                                <td>@acuse.FechaHoraFirma.ToString("dd/MM/yyyy")</td>
                                <td>@acuse.FechaHoraFirma.ToString("hh:mm tt")</td>
                            </tr>
                            contador++;
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="p-5 text-muted fs-5 fw-bold">
                                <i class="bi bi-person-x fs-1 d-block mb-2"></i>
                                Nadie ha firmado este aviso todavía.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            
            <div class="mt-5 text-center text-muted" style="font-size: 0.8rem;">
                <p>Documento de auditoría generado automáticamente por el Sistema Hotel San Pedro.</p>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }
</style>

<!-- LIBRERÍA Y SCRIPT PARA GENERAR EL PDF MÁGICAMENTE -->
@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script>
        function descargarPDF(elementoId, nombreArchivo) {
        var elemento = document.getElementById(elementoId);
            
        // Opciones de configuración para que parezca hoja de máquina (Carta/Letter)
        var opt = {
        margin:       0.5,
        filename:     nombreArchivo + '.pdf',
        image:        { type: 'jpeg', quality: 0.98 },
        html2canvas:  { scale: 2, useCORS: true },
        jsPDF:        { unit: 'in', format: 'letter', orientation: 'portrait' }
        };

        // Mandamos a crear y descargar el PDF
        html2pdf().set(opt).from(elemento).save();
        }
    </script>
}