@model WestBesternoficialya.Models.Usuario

<div class="container mt-4">
    <h2>Editar Empleado</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form asp-action="Edit" method="post">
                <!-- ID oculto -->
                <input type="hidden" asp-for="Id" />
                
                <div class="mb-3">
                    <label class="form-label">Nombre Completo</label>
                    <input asp-for="NombreCompleto" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Correo Electrónico</label>
                    <input asp-for="Email" type="email" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input asp-for="Password" type="password" class="form-control" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Departamento asignado</label>
                    <select asp-for="DepartamentoId" class="form-control" asp-items="ViewBag.Departamentos"></select>
                </div>

                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </form>
        </div>
    </div>
</div>