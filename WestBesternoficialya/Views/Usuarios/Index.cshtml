@model IEnumerable<WestBesternoficialya.Models.Usuario>

@{
    ViewData["Title"] = "Personal del Hotel";
}

<div class="container mt-4">
    <h2>Personal del Hotel</h2>
    <a asp-action="Create" class="btn btn-primary mb-3">Registrar Nuevo Empleado</a>
    <hr />

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>Nombre</th>
                <th>Correo</th>
                <th>Departamento</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var usuario in Model)
            {
                <tr>
                    <td>@usuario.NombreCompleto</td>
                    <td>@usuario.Email</td>
                    <td>@usuario.Departamento.Nombre</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@usuario.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@usuario.Id" class="btn btn-danger btn-sm">Borrar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>