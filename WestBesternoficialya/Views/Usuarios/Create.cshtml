@model WestBesternoficialya.Models.Usuario

@{
    ViewData["Title"] = "Nuevo Empleado";
}

<div class="container mt-4">
    <h2>Registrar Nuevo Empleado</h2>
    <hr />

    <div class="row">
        <div class="col-md-6">
            <form asp-action="Create" method="post">

                <div class="mb-3">
                    <label class="form-label">Nombre Completo</label>
                    <input asp-for="NombreCompleto" class="form-control" placeholder="Ej. Juan Pérez" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Correo Electrónico</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="juan@hotel.com" required />
                </div>

                <div class="mb-3">
                    <label class="form-label">Contraseña</label>
                    <input asp-for="Password" type="password" class="form-control" required />
                </div>

                <div class="mb-3">
                    <label class="form-label text-primary fw-bold">Departamento asignado (Da permisos automáticos)</label>
                    <select asp-for="DepartamentoId" class="form-control border-primary shadow-sm" asp-items="ViewBag.Departamentos" required>
                        <option value="">-- Selecciona un Departamento --</option>
                    </select>
                </div>

                <button type="submit" class="btn btn-success fw-bold shadow-sm">Guardar Empleado</button>
                <a asp-action="Index" class="btn btn-secondary shadow-sm">Cancelar</a>

            </form>
        </div>
    </div>
</div>