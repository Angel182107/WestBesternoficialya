<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - WestBesternoficialya</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WestBesternoficialya.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">Hotel San Pedro</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    
                   <ul class="navbar-nav flex-grow-1">
                        
                        @if (User.IsInRole("Administrador"))
                        {
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Departamentos" asp-action="Index">🏢 Departamentos</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Usuarios" asp-action="Index">👥 Personal</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Productos" asp-action="Index">📦 Almacén</a>
                            </li>
                            <li class="nav-item">
    <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Mantenimiento" asp-action="Index">
        <i class="bi bi-tools text-secondary"></i> Mantenimiento
    </a>
</li>
                        }
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold" asp-area="" asp-controller="Eventos" asp-action="Index">📢 Avisos</a>
                        </li>

                    </ul>

<ul class="navbar-nav align-items-center gap-3">
    
    <li class="nav-item dropdown position-relative">
        <a class="nav-link text-dark fs-5" href="#" id="campanaDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-bell-fill"></i>
            <span id="contador-notificaciones" class="position-absolute top-25 start-75 translate-middle badge rounded-pill bg-danger" style="display:none; font-size: 0.65rem;">
                0
            </span>
        </a>
        
        <ul class="dropdown-menu dropdown-menu-end shadow" aria-labelledby="campanaDropdown" style="min-width: 300px;">
            <li><h6 class="dropdown-header fw-bold text-dark">Notificaciones Recientes</h6></li>
            <li><hr class="dropdown-divider"></li>
            
            <li>
                <a class="dropdown-item text-wrap" asp-controller="NotificacionesEventos" asp-action="Index">
                    <i class="bi bi-info-circle-fill text-primary me-2"></i> Tienes nuevos formatos pendientes de revisar.
                </a>
            </li>
            
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item text-center fw-bold text-primary" asp-controller="NotificacionesEventos" asp-action="Index">
                    Ver todas las notificaciones
                </a>
            </li>
        </ul>
    </li>

    <li class="nav-item">
        <a class="btn btn-outline-danger fw-bold shadow-sm" asp-area="" asp-controller="Acceso" asp-action="Salir">
            <i class="bi bi-box-arrow-right"></i> Cerrar Sesión
        </a>
    </li>
</ul>

                </div
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Sistema Hotel San Pedro - <a asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
    <script>
        function actualizarCampanita() {
            $.get('/NotificacionesEventos/ObtenerContador', function(cantidad) {
                let badge = $('#contador-notificaciones');
                if (cantidad > 0) {
                    badge.text(cantidad);
                    badge.show(); // Muestra la burbujita roja
                } else {
                    badge.hide(); // Oculta la burbujita roja (la campana sigue visible)
                }
            }).fail(function() {
                console.log("No se pudo obtener el contador de notificaciones.");
            });
        }

        $(document).ready(function() {
            actualizarCampanita();
            setInterval(actualizarCampanita, 30000);
        });
    </script>
</body>
</html>