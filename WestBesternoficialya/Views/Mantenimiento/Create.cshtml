@model WestBesternoficialya.Models.MaterialMantenimiento

@{
    ViewData["Title"] = "Registro de Inventario";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-header bg-primary text-white text-center py-3 rounded-top-4">
                    <h4 class="mb-0 fw-bold"><i class="bi bi-tools me-2"></i> Captura de Inventario</h4>
                </div>
                
                <div class="card-body p-4 bg-light">
                    <form asp-action="Create" method="post">
                        
                        <div class="mb-4">
                            <label asp-for="Fecha" class="form-label fw-bold text-secondary">Fecha del Reporte</label>
                            <input asp-for="Fecha" type="date" class="form-control form-control-lg border-0 shadow-sm" required />
                        </div>

                        <div class="mb-4">
                            <label asp-for="Marca" class="form-label fw-bold text-secondary">Marca / Material</label>
                            <input asp-for="Marca" class="form-control form-control-lg border-0 shadow-sm" placeholder="Ej. Ceys, Silicona Stop Moho" required />
                        </div>

                        <div class="row mb-4">
                            <div class="col-md-4 mb-3 mb-md-0">
                                <label asp-for="Maximo" class="form-label fw-bold text-primary">Máximo</label>
                                <input asp-for="Maximo" type="number" min="0" class="form-control border-0 shadow-sm text-center fw-bold" placeholder="Ej. 10" required />
                            </div>

                            <div class="col-md-4 mb-3 mb-md-0">
                                <label asp-for="Minimo" class="form-label fw-bold text-warning">Mínimo</label>
                                <input asp-for="Minimo" type="number" min="0" class="form-control border-0 shadow-sm text-center fw-bold" placeholder="Ej. 3" required />
                            </div>

                            <div class="col-md-4">
                                <label asp-for="Existencia" class="form-label fw-bold text-success">Existencia</label>
                                <input asp-for="Existencia" type="number" min="0" class="form-control border-0 shadow-sm text-center fw-bold" placeholder="¿Cuántos hay?" required />
                            </div>
                        </div>

                        <div class="alert alert-info border-0 shadow-sm mb-4">
                            <i class="bi bi-calculator-fill me-2"></i>
                            <strong>Nota:</strong> El sistema calculará automáticamente la cantidad a <strong>COMPRAR</strong> para alcanzar el stock máximo.
                        </div>

                        <div class="d-grid gap-2 d-md-flex justify-content-md-end mt-4">
                            <a asp-action="Index" class="btn btn-secondary btn-lg shadow-sm px-4">Cancelar</a>
                            <button type="submit" class="btn btn-success btn-lg shadow-sm px-5 fw-bold">
                                <i class="bi bi-save me-1"></i> Guardar Registro
                            </button>
                        </div>

                    </form>
                </div>
            </div>

        </div>
    </div>
</div>