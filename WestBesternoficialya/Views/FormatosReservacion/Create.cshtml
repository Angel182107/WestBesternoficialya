@model WestBesternoficialya.Models.FormatoReservacion

<div class="container mt-4">
    <h2 class="text-primary fw-bold">📄 Nueva Reservación de Grupo (Cotización)</h2>
    <hr />

    <form asp-action="Create" method="post">
        <div class="row">

            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary text-white fw-bold">1. VINCULACIÓN AL GRUPO Y ENCABEZADO</div>
                    <div class="card-body row g-2">
                        <div class="col-md-12 mb-3">
                            <label class="form-label fw-bold text-primary">🔗 ¿A qué Grupo/Instructivo pertenece esta cotización?</label>
                            <select asp-for="EventoId" class="form-select border-primary" asp-items="ViewBag.EventoId" required>
                                <option value="">-- Selecciona el Grupo (Instructivo) --</option>
                            </select>
                        </div>

                        <div class="col-md-3"><label class="form-label">Folio de Reservación</label><input asp-for="Folio" class="form-control" /></div>
                        <div class="col-md-3"><label class="form-label">Fecha Elaboración</label><input asp-for="FechaElaboracion" type="date" asp-format="{0:yyyy-MM-dd}" class="form-control" /></div>
                        <div class="col-md-6"><label class="form-label">Nombre del Grupo</label><input asp-for="NombreGrupo" class="form-control" /></div>

                        <div class="col-md-6 mt-2"><label class="form-label">Persona que solicita</label><input asp-for="PersonaQueSolicita" class="form-control" /></div>
                        <div class="col-md-3 mt-2"><label class="form-label">Teléfono</label><input asp-for="Telefono" class="form-control" /></div>
                        <div class="col-md-3 mt-2"><label class="form-label">Email</label><input asp-for="Email" type="email" class="form-control" /></div>
                    </div>
                </div>
            </div>

            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-info">
                    <div class="card-header bg-info text-dark fw-bold">2. DETALLES DE ESTANCIA</div>
                    <div class="card-body row g-2">
                        <div class="col-md-3"><label class="form-label">Fecha de Entrada</label><input asp-for="FechaEntrada" type="date" asp-format="{0:yyyy-MM-dd}" class="form-control" /></div>
                        <div class="col-md-3"><label class="form-label">Fecha de Salida</label><input asp-for="FechaSalida" type="date" asp-format="{0:yyyy-MM-dd}" class="form-control" /></div>
                        <div class="col-md-3"><label class="form-label">Total de Noches</label><input asp-for="TotalNoches" type="number" class="form-control" /></div>
                        <div class="col-md-3"><label class="form-label">Total Habitaciones</label><input asp-for="TotalHabitaciones" type="number" class="form-control" /></div>
                    </div>
                </div>
            </div>

            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-secondary">
                    <div class="card-header bg-secondary text-white fw-bold">3. DESGLOSE Y TARIFAS DE HABITACIONES</div>
                    <div class="card-body overflow-auto">
                        <table class="table table-bordered text-center align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Tipo de Habitación</th>
                                    <th>Cantidad</th>
                                    <th>Tarifa $</th>
                                    <th>Total Parcial $</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr>
                                    <td class="fw-bold">Sencilla</td>
                                    <td><input asp-for="CantidadSencilla" type="number" class="form-control text-center" /></td>
                                    <td><input asp-for="TarifaSencilla" type="number" step="0.01" class="form-control text-center" /></td>
                                    <td><input asp-for="TotalSencilla" type="number" step="0.01" class="form-control text-center bg-light" /></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Doble</td>
                                    <td><input asp-for="CantidadDoble" type="number" class="form-control text-center" /></td>
                                    <td><input asp-for="TarifaDoble" type="number" step="0.01" class="form-control text-center" /></td>
                                    <td><input asp-for="TotalDoble" type="number" step="0.01" class="form-control text-center bg-light" /></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Triple</td>
                                    <td><input asp-for="CantidadTriple" type="number" class="form-control text-center" /></td>
                                    <td><input asp-for="TarifaTriple" type="number" step="0.01" class="form-control text-center" /></td>
                                    <td><input asp-for="TotalTriple" type="number" step="0.01" class="form-control text-center bg-light" /></td>
                                </tr>
                                <tr>
                                    <td class="fw-bold">Cuádruple</td>
                                    <td><input asp-for="CantidadCuadruple" type="number" class="form-control text-center" /></td>
                                    <td><input asp-for="TarifaCuadruple" type="number" step="0.01" class="form-control text-center" /></td>
                                    <td><input asp-for="TotalCuadruple" type="number" step="0.01" class="form-control text-center bg-light" /></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-success">
                    <div class="card-header bg-success text-white fw-bold">4. IMPUESTOS Y COBROS</div>
                    <div class="card-body row g-2 align-items-end">
                        <div class="col-md-3"><label class="form-label">Subtotal</label><input asp-for="Subtotal" type="number" step="0.01" class="form-control" /></div>
                        <div class="col-md-3"><label class="form-label">IVA (16%)</label><input asp-for="Iva" type="number" step="0.01" class="form-control" /></div>
                        <div class="col-md-3"><label class="form-label">ISH (3%)</label><input asp-for="Ish" type="number" step="0.01" class="form-control" /></div>
                        <div class="col-md-3"><label class="form-label fw-bold text-success fs-5">TOTAL $</label><input asp-for="Total" type="number" step="0.01" class="form-control border-success fw-bold fs-5 text-success" /></div>

                        <div class="col-md-6 mt-4"><label class="form-label text-danger fw-bold">Anticipo Requerido $</label><input asp-for="AnticipoRequerido" type="number" step="0.01" class="form-control border-danger" /></div>
                        <div class="col-md-6 mt-4"><label class="form-label text-danger fw-bold">Fecha Límite de Anticipo</label><input asp-for="FechaLimiteAnticipo" type="date" asp-format="{0:yyyy-MM-dd}" class="form-control border-danger" /></div>
                    </div>
                </div>
            </div>

            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-warning">
                    <div class="card-header bg-warning text-dark fw-bold">5. POLÍTICAS Y OBSERVACIONES FINALES</div>
                    <div class="card-body row g-2">
                        <div class="col-md-12">
                            <label class="form-label">Políticas de Cancelación</label>
                            <textarea asp-for="PoliticasCancelacion" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-md-12 mt-3">
                            <label class="form-label">Observaciones de la Cotización</label>
                            <textarea asp-for="Observaciones" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="mt-4 mb-5 text-center d-print-none">
            <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm">💾 Guardar Cotización</button>
            <a asp-action="Index" asp-controller="Eventos" class="btn btn-secondary btn-lg px-5 ms-3 shadow-sm">Cancelar</a>
        </div>
    </form>
</div>