@model IEnumerable<WestBesternoficialya.Models.Departamento>

@{
    ViewData["Title"] = "Departamentos";
}

<div class="container mt-4">
    <h2>Catálogo de Departamentos</h2>
    
    <a asp-action="Create" class="btn btn-primary mb-3">Agregar Nuevo Departamento</a>
    
    <hr />

    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <!-- Quitamos el <th> del ID de aquí arriba -->
                <th>Nombre del Departamento</th>
                <th>Acciones</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var depto in Model)
            {
                <tr>
                    <!-- Quitamos el <td> del ID de aquí adentro -->
                    <td>@depto.Nombre</td>
                    <td>
                        <!-- Fíjate que el ID sigue aquí adentro de los botones (asp-route-id),
                             así el sistema sabe cuál borrar, pero el usuario ya no lo ve escrito en la tabla -->
                        <a asp-action="Edit" asp-route-id="@depto.Id" class="btn btn-warning btn-sm">Editar</a>
                        <a asp-action="Delete" asp-route-id="@depto.Id" class="btn btn-danger btn-sm">Borrar</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>