<!-- En esta primera línea le decimos a la vista qué tipo de datos va a recibir del Controlador -->
@model IEnumerable<WestBesternoficialya.Models.Departamento>

@{
    ViewData["Title"] = "Departamentos";
}

<div class="container mt-4">
    <h2>Catálogo de Departamentos</h2>
    <hr />

    <!-- Usamos clases de Bootstrap 5 para que la tabla se vea moderna y responsiva -->
    <table class="table table-striped table-hover mt-3">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Nombre del Departamento</th>
            </tr>
        </thead>
        <tbody>
            <!-- Aquí hacemos un ciclo para imprimir cada departamento que llegó de la base de datos -->
            @foreach (var depto in Model)
            {
                <tr>
                    <td>@depto.Id</td>
                    <td>@depto.Nombre</td>
                </tr>
            }
        </tbody>
    </table>
</div>