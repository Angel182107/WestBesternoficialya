@model WestBesternoficialya.Models.NotificacionEvento

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="text-primary fw-bold">🍽️ Notificación de Evento (Alimentos y Salones)</h2>
        <span class="badge bg-success fs-6 px-3 py-2">Vinculado al Aviso #@Model.EventoId</span>
    </div>
    <hr />

    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="EventoId" />

        <div class="row">
            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary text-white fw-bold">1. DATOS GENERALES</div>
                    <div class="card-body row g-2">
                        <div class="col-md-3">
                            <label class="form-label">Folio</label>
                            <input asp-for="Folio" class="form-control" placeholder="Ej. 8872" />
                        </div>
                        <div class="col-md-9">
                            <label class="form-label">Fechas del Evento</label>
                            <input asp-for="FechaEvento" class="form-control" placeholder="Ej. 02 Y 03 DE ABRIL" />
                        </div>
                        <div class="col-md-6 mt-3">
                            <label class="form-label">Cliente y/o Empresa</label>
                            <input asp-for="ClienteEmpresa" class="form-control" placeholder="Ej. AZTECA TOURS" />
                        </div>
                        <div class="col-md-6 mt-3">
                            <label class="form-label">Ejecutivo</label>
                            <input asp-for="Ejecutivo" class="form-control" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-info">
                    <div class="card-header bg-info text-dark fw-bold">2. LOGÍSTICA DE MONTAJE Y SERVICIO</div>
                    <div class="card-body row g-2">
                        <div class="col-md-6">
                            <label class="form-label">Concepto / Menú</label>
                            <input asp-for="ConceptoServicio" class="form-control" placeholder="Ej. DESAYUNO AMERICANO" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label">Horario</label>
                            <input asp-for="Horario" class="form-control" placeholder="Ej. 07:00 AM" />
                        </div>
                        <div class="col-md-6 mt-3">
                            <label class="form-label">Lugar / Salón</label>
                            <input asp-for="Lugar" class="form-control" placeholder="Ej. RESTAURANTE / JARDIN" />
                        </div>
                        <div class="col-md-6 mt-3">
                            <label class="form-label">Tipo de Montaje</label>
                            <input asp-for="Montaje" class="form-control" placeholder="Ej. NORMAL" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-success">
                    <div class="card-header bg-success text-white fw-bold">3. COSTOS FINANCIEROS (Ocultos para Operaciones)</div>
                    <div class="card-body row g-2 align-items-end">
                        <div class="col-md-3">
                            <label class="form-label">Precio Unitario $</label>
                            <input asp-for="Precio" type="number" step="0.01" class="form-control text-center" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">IVA (16%)</label>
                            <input asp-for="Iva" type="number" step="0.01" class="form-control text-center" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Servicio (Propina)</label>
                            <input asp-for="Servicio" type="number" step="0.01" class="form-control text-center" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Subtotal por Persona</label>
                            <input asp-for="Subtotal" type="number" step="0.01" class="form-control text-center bg-light" />
                        </div>

                        <div class="col-md-4 mt-4">
                            <label class="form-label">Número de Pax (Personas)</label>
                            <input asp-for="NoPax" type="number" class="form-control text-center" />
                        </div>
                        <div class="col-md-4 mt-4">
                            <label class="form-label">Número de Días</label>
                            <input asp-for="NoDias" type="number" class="form-control text-center" />
                        </div>
                        <div class="col-md-4 mt-4">
                            <label class="form-label fw-bold text-success fs-5">TOTAL $</label>
                            <input asp-for="Total" type="number" step="0.01" class="form-control border-success fw-bold text-success fs-5 text-center" />
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-warning">
                    <div class="card-header bg-warning text-dark fw-bold">4. CORTESÍAS, PAGOS Y OBSERVACIONES</div>
                    <div class="card-body row g-2">
                        <div class="col-md-12">
                            <label class="form-label">Cortesías Especiales</label>
                            <textarea asp-for="Cortesias" class="form-control" rows="2" placeholder="Ej. Plato de cortesía para coordinador..."></textarea>
                        </div>
                        <div class="col-md-12 mt-3">
                            <label class="form-label fw-bold">Método de Pago / Instrucción</label>
                            <input asp-for="Pago" class="form-control border-warning" placeholder="Ej. CARGAR A RECEPCION" />
                        </div>
                        <div class="col-md-12 mt-3">
                            <label class="form-label">Observaciones Generales</label>
                            <textarea asp-for="Observaciones" class="form-control" rows="3" placeholder="Ej. Cuidar detalles en presentación..."></textarea>
                        </div>
                    </div>
                </div>
            </div>

        </div>

        <div class="mt-4 mb-5 text-center d-print-none">
            <button type="submit" class="btn btn-primary btn-lg fw-bold px-5 shadow-sm">
                <i class="fa-solid fa-save"></i> Guardar Formato de Alimentos
            </button>
            <a asp-action="Index" asp-controller="Eventos" class="btn btn-secondary btn-lg px-5 ms-3 shadow-sm">
                Cancelar
            </a>
        </div>
    </form>
</div>