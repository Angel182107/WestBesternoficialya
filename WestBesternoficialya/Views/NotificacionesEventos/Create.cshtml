@model WestBesternoficialya.Models.NotificacionEvento

<div class="container mt-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Crear Notificación de Evento (Alimentos)</h2>
        <span class="badge bg-success fs-6 px-3 py-2">Vinculado al Aviso #@Model.EventoId</span>
    </div>
    <hr />

    <form asp-action="Create" method="post">
        <input type="hidden" asp-for="EventoId" />

        <div class="formato-impresion shadow-sm" style="max-width: 1000px; margin: auto; background-color: white; padding: 30px; border: 1px solid #ccc; font-family: Arial, sans-serif;">

            <div class="text-center fw-bold border border-dark p-2 mb-0 d-flex justify-content-center align-items-center" style="background-color: #d1d1d1;">
                NOTIFICACIÓN DE EVENTO FOLIO <input asp-for="Folio" class="form-control form-control-sm ms-2 w-auto border-dark text-center bg-white" placeholder="____" />
            </div>

            <table class="table table-bordered border-dark text-center mt-0 mb-0" style="font-size: 0.9rem;">
                <tbody>
                    <tr>
                        <td style="width: 50%;">@(DateTime.Now.ToString("dd/MM/yyyy"))</td>
                        <td style="width: 50%;" class="fw-bold bg-light">FECHA DE EVENTO:</td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light">CLIENTE Y/O EMPRESA:</td>
                        <td class="p-0"><input asp-for="FechaEvento" class="form-control border-0 text-center bg-transparent w-100" placeholder="Ej. 02 Y 03 DE ABRIL" /></td>
                    </tr>
                    <tr>
                        <td class="p-0"><input asp-for="ClienteEmpresa" class="form-control border-0 fw-bold fs-5 text-center text-uppercase bg-transparent w-100" placeholder="NOMBRE DE LA EMPRESA" /></td>
                        <td class="p-0">
                            <table class="table table-borderless m-0 h-100 w-100">
                                <tr>
                                    <td style="width: 30%; border-right: 1px solid black;" class="fw-bold bg-light align-middle">EJECUTIVO:</td>
                                    <td class="p-0 align-middle"><input asp-for="Ejecutivo" class="form-control border-0 text-center bg-transparent w-100" /></td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                </tbody>
            </table>

            <table class="table table-bordered border-dark text-center mt-3 mb-0" style="font-size: 0.9rem;">
                <tbody>
                    <tr>
                        <td style="width: 50%;" class="fw-bold bg-light">HORARIO:</td>
                        <td style="width: 50%;"></td>
                    </tr>
                    <tr>
                        <td class="p-0"><input asp-for="ConceptoServicio" class="form-control border-0 fw-bold fs-5 text-center bg-transparent w-100" placeholder="Ej. DESAYUNO AMERICANO" /></td>
                        <td class="p-0"><input asp-for="Horario" type="time" class="form-control border-0 text-center fw-bold bg-transparent w-100" /></td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light">LUGAR:</td>
                        <td class="fw-bold bg-light">MONTAJE:</td>
                    </tr>
                    <tr>
                        <td class="p-0"><input asp-for="Lugar" class="form-control border-0 text-center bg-transparent w-100" placeholder="Ej. RESTAURANTE / JARDIN" /></td>
                        <td class="p-0"><input asp-for="Montaje" class="form-control border-0 text-center bg-transparent w-100" placeholder="Ej. NORMAL" /></td>
                    </tr>
                </tbody>
            </table>

            <div class="fw-bold text-center border border-dark border-bottom-0 mt-3" style="background-color: #d1d1d1;">COSTOS:</div>
            <table class="table table-bordered border-dark text-center mb-0" style="font-size: 0.85rem;">
                <thead style="background-color: #ffff00;">
                    <tr>
                        <th style="width: 15%;" class="bg-light">CONCEPTO:</th>
                        <th style="width: 17%;"></th>
                        <th style="width: 17%;"></th>
                        <th style="width: 17%;"></th>
                        <th style="width: 17%;"></th>
                        <th style="width: 17%;"></th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-bold bg-light align-middle">PRECIO:</td>
                        <td class="p-0"><input asp-for="Precio" type="number" step="0.01" class="form-control border-0 text-center bg-transparent w-100" /></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light align-middle">IVA:</td>
                        <td class="p-0"><input asp-for="Iva" type="number" step="0.01" class="form-control border-0 text-center bg-transparent w-100" /></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light align-middle">SERVICIO:</td>
                        <td class="p-0"><input asp-for="Servicio" type="number" step="0.01" class="form-control border-0 text-center bg-transparent w-100" /></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light align-middle">SUBTOTAL:</td>
                        <td class="p-0"><input asp-for="Subtotal" type="number" step="0.01" class="form-control border-0 text-center bg-transparent w-100" /></td>
                        <td></td>
                        <td></td>
                        <td></td>
                        <td></td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light align-middle">NO. PAX:</td>
                        <td class="p-0"><input asp-for="NoPax" type="number" class="form-control border-0 text-center fw-bold bg-transparent w-100" /></td>
                        <td class="p-0"><input asp-for="NoPax2" type="number" class="form-control border-0 text-center fw-bold bg-transparent w-100" /></td>
                        <td class="p-0"><input asp-for="NoPax3" type="number" class="form-control border-0 text-center fw-bold bg-transparent w-100" /></td>
                        <td class="p-0"><input asp-for="NoPax4" type="number" class="form-control border-0 text-center fw-bold bg-transparent w-100" /></td>
                        <td class="p-0"><input asp-for="NoPax5" type="number" class="form-control border-0 text-center fw-bold bg-transparent w-100" /></td>
                    </tr>
                    <tr>
                        <td class="fw-bold bg-light align-middle">NO. DÍAS:</td>
                        <td class="p-0"><input asp-for="NoDias" type="number" class="form-control border-0 text-center bg-transparent w-100" /></td>
                        <td class="p-0"><input asp-for="NoDias2" type="number" class="form-control border-0 text-center bg-transparent w-100" /></td>
                        <td class="p-0"><input asp-for="NoDias3" type="number" class="form-control border-0 text-center bg-transparent w-100" /></td>
                        <td class="p-0"><input asp-for="NoDias4" type="number" class="form-control border-0 text-center bg-transparent w-100" /></td>
                        <td class="p-0"><input asp-for="NoDias5" type="number" class="form-control border-0 text-center bg-transparent w-100" /></td>
                    </tr>
                    <tr>
                        <td colspan="2" class="fw-bold bg-light text-end pe-3 align-middle">TOTAL:</td>
                        <td class="p-0"><input asp-for="Total" type="number" step="0.01" class="form-control border-0 text-center fw-bold fs-6 bg-transparent w-100" /></td>
                        <td colspan="3" class="fw-bold fs-6"></td>
                    </tr>
                </tbody>
            </table>

            <table class="table table-bordered border-dark text-center mt-0 mb-0 border-top-0" style="font-size: 0.9rem;">
                <tbody>
                    <tr>
                        <td style="width: 50%;" class="fw-bold bg-light">CORTESÍAS:</td>
                        <td style="width: 50%;" class="fw-bold bg-light">PAGO:</td>
                    </tr>
                    <tr>
                        <td class="p-0"><textarea asp-for="Cortesias" class="form-control border-0 text-center fw-bold text-uppercase bg-transparent w-100" rows="2"></textarea></td>
                        <td class="p-0"><input asp-for="Pago" class="form-control border-0 text-center fw-bold text-decoration-underline mt-2 bg-transparent w-100" placeholder="Ej. CARGAR A RECEPCION" /></td>
                    </tr>
                    <tr>
                        <!-- SECCIÓN CORREGIDA: Notas Izquierda y Observaciones Derecha -->
                        <td rowspan="2" class="p-0 align-middle">
                            <textarea asp-for="NotasAdicionales" class="form-control border-0 text-center fw-bold bg-transparent w-100 h-100" rows="3" style="color: black;" placeholder="Ej. CUIDAR DETALLES EN PRESENTACION..."></textarea>
                        </td>
                        <td class="fw-bold bg-light text-start ps-3 border-bottom-0">OBSERVACIONES:</td>
                    </tr>
                    <tr>
                        <td class="p-0 border-top-0" style="background-color: #ffff00;">
                            <textarea asp-for="Observaciones" class="form-control border-0 text-center fw-bold fs-5 text-uppercase w-100" rows="2" style="background-color: transparent !important; color: black;" placeholder="EXTRANJEROS / COSTA RICA"></textarea>
                        </td>
                    </tr>
                </tbody>
            </table>

            <table class="table table-bordered border-dark text-center mt-0 mb-0 border-top-0" style="font-size: 0.9rem;">
                <tbody>
                    <tr>
                        <td class="fw-bold bg-light align-middle" style="width: 50%;">
                            <div class="d-flex align-items-center justify-content-center">
                                ESTACIONAMIENTO:
                                <input asp-for="Estacionamiento" class="form-control border-0 bg-transparent ms-2 w-50 fw-bold" placeholder="..." />
                            </div>
                        </td>
                        <td class="p-0" style="width: 50%;">
                            <table class="table table-borderless m-0 h-100 w-100">
                                <tr>
                                    <td class="fw-bold bg-light border-bottom border-end border-dark" style="width: 50%;">PREPARAR:</td>
                                    <td class="p-0 border-bottom border-dark" style="width: 50%;">
                                        <input asp-for="Preparar" type="number" class="form-control border-0 text-center fw-bold h-100 bg-transparent w-100" />
                                    </td>
                                </tr>
                                <tr>
                                    <td class="fw-bold bg-light border-end border-dark">GARANTÍA:</td>
                                    <td class="p-0">
                                        <input asp-for="Garantia" type="number" class="form-control border-0 text-center fw-bold h-100 bg-transparent w-100" />
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    <tr>
                        <td colspan="2" class="fw-bold bg-light fs-6 text-start ps-3">MENÚS:</td>
                    </tr>
                    <tr>
                        <td colspan="2" class="p-0">
                            <textarea asp-for="Menus" class="form-control border-0 text-center fw-bold text-uppercase bg-transparent w-100" rows="4" placeholder="Ej. CAFÉ AMERICANO O TE..."></textarea>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="mt-4 mb-5 text-center d-print-none">
            <button type="submit" class="btn btn-success btn-lg fw-bold px-5 shadow-sm">
                <i class="bi bi-save"></i> Guardar Formato de Alimentos
            </button>
            <a asp-action="Index" asp-controller="Eventos" class="btn btn-secondary btn-lg px-5 ms-3 shadow-sm">Cancelar</a>
        </div>
    </form>
</div>

<style>
    .bg-light {
        background-color: #f8f9fa !important;
    }

    input.border-0, textarea.border-0 {
        background-color: #fcfcfc !important;
        outline: none;
    }

        input.border-0:focus, textarea.border-0:focus {
            background-color: #e9ecef !important;
        }
</style>